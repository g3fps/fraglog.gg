{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/admin.html",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/lineup-admin.html",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/coaching-admin.html",
      "destination": "/404",
      "permanent": false
    }
  ]
}