---
// ProMatchModal.astro
// Usage: <ProMatchModal /> then call window.openProMatch(match) from JS
---

<div class="pro-modal-backdrop" id="pro-match-modal" onclick="closeProModal(event)">
  <div class="pro-modal">
    <div class="pro-modal-header">
      <div>
        <div class="pro-modal-title" id="pro-modal-title"></div>
        <div class="pro-modal-meta" id="pro-modal-meta"></div>
      </div>
      <button class="pro-modal-close" onclick="closeProModal()">✕</button>
    </div>
    <div class="pro-modal-body">
      <div class="pro-map-tabs" id="pro-map-tabs"></div>
      <div class="pro-video-wrap">
        <iframe id="pro-modal-video" src="" frameborder="0" allowfullscreen></iframe>
      </div>
    </div>
  </div>
</div>

<script is:inline>
window.openProMatch = function(match) {
  const m = match;
  document.getElementById('pro-modal-title').textContent = `${m.team1} vs ${m.team2}`;
  document.getElementById('pro-modal-meta').textContent = m.event + (m.date ? ' · ' + new Date(m.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '');

  const maps = [
    { map: m.map1, ytId: m.map1_youtube_id, start: m.map1_start_time || 0 },
    { map: m.map2, ytId: m.map2_youtube_id, start: m.map2_start_time || 0 },
    m.map3 ? { map: m.map3, ytId: m.map3_youtube_id, start: m.map3_start_time || 0 } : null,
    m.map4 ? { map: m.map4, ytId: m.map4_youtube_id, start: m.map4_start_time || 0 } : null,
    m.map5 ? { map: m.map5, ytId: m.map5_youtube_id, start: m.map5_start_time || 0 } : null,
  ].filter(Boolean);

  document.getElementById('pro-map-tabs').innerHTML = maps.map((mp, i) => `
    <button class="pro-map-tab ${i === 0 ? 'active' : ''}" onclick="switchProMap(${i})" data-yt="${mp.ytId}" data-start="${mp.start}">
      ${mp.map}
    </button>
  `).join('');

  document.getElementById('pro-modal-video').src = `https://www.youtube.com/embed/${maps[0].ytId}?start=${maps[0].start}&autoplay=1`;
  document.getElementById('pro-match-modal').classList.add('open');
};

window.switchProMap = function(index) {
  document.querySelectorAll('#pro-map-tabs .pro-map-tab').forEach((t, i) => t.classList.toggle('active', i === index));
  const tab = document.querySelectorAll('#pro-map-tabs .pro-map-tab')[index];
  document.getElementById('pro-modal-video').src = `https://www.youtube.com/embed/${tab.dataset.yt}?start=${tab.dataset.start || 0}&autoplay=1`;
};

window.closeProModal = function(e) {
  if (e && e.target !== document.getElementById('pro-match-modal')) return;
  document.getElementById('pro-match-modal').classList.remove('open');
  document.getElementById('pro-modal-video').src = '';
};
</script>