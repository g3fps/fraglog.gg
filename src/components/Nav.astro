---
const { crumbs = [], user = null } = Astro.props as { crumbs: { label: string; href?: string }[], user: any };
---

<header class="site-header">
  <div class="nav-top">
    <a class="logo" href="/">FragLog<span>.gg</span></a><span class="nav-premium-badge" id="nav-premium-badge" style="display:none">✦</span>
    <div class="nav-top-right">
      <div class="nav-right" id="nav-right">
        {user ? (
          <>
            <a class="user-pill" href="/settings">
              <div class="user-avatar" id="nav-avatar-wrap">
                <img id="nav-avatar-img" src="" alt="">
                <span id="nav-avatar-initials">{user.email[0].toUpperCase()}</span>
              </div>
              <span id="nav-username">{user.email.split("@")[0]}</span>
            </a>
            <button class="auth-btn" onclick="signOut()">Sign Out</button>
          </>
        ) : (
          <>
            <button class="auth-btn" onclick="openAuth()">Sign In</button>
            <button class="auth-btn primary" onclick="openAuth('register')">Sign Up</button>
          </>
        )}
      </div>
    </div>
  </div>

  <div class="nav-bottom">
    <div class="feature-tabs">
      <a class="feature-tab" href="/" id="tab-vods">Ranked</a>
      <a class="feature-tab" href="/pro" id="tab-pro">Pro</a>
      <a class="feature-tab" href="/gameplan" id="tab-gameplan">Gameplan</a>
      <a class="feature-tab" href="/coach" id="tab-coach">Coach</a>
    </div>
    <div class="nav-bottom-right">
      <a class="feature-tab feature-tab--premium" href="/premium" id="tab-premium">✦ Premium</a>
      <a class="feature-tab" href="/favorites" id="tab-favorites" style="display:none"><span class="fav-heart">♥ </span>Favorites</a>
      <a class="feature-tab" href="/my-vods" id="tab-myvods" style="display:none">My VODs</a>
      <a class="feature-tab" href="/playlists" id="tab-playlists" style="display:none">Playlists</a>
    </div>
  </div>
</header>

<script is:inline>
function handleNavSearch(val) {
  if (!val.trim()) return;
  window.location.href = '/search?q=' + encodeURIComponent(val.trim());
}

// Active tab
(function() {
  const path = window.location.pathname;
  const map = { '/pro': 'tab-pro', '/gameplan': 'tab-gameplan', '/favorites': 'tab-favorites', '/coach': 'tab-coach', '/notes': 'tab-coach', '/my-vods': 'tab-myvods', '/playlists': 'tab-playlists', '/premium': 'tab-premium' };
  const matched = Object.entries(map).find(([p]) => path.startsWith(p));
  document.getElementById(matched ? matched[1] : 'tab-vods')?.classList.add('active');
})();

(async function initNav() {
  try {
    const sb = window._supabase || (typeof supabase !== 'undefined' && supabase.createClient(
      "https://cvdtykmkajmhlxydhzzl.supabase.co",
      "sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi",
      { auth: { persistSession: true, storageKey: 'sb-session', storage: window.localStorage } }
    ));
    if (!sb) return;
    const { data: { session } } = await sb.auth.getSession();
    if (!session) return;

    // Show favorites/my vods/playlists tabs (notes is always visible, gated on its own page)
    document.getElementById('tab-favorites').style.display = '';
    document.getElementById('tab-myvods').style.display = '';
    document.getElementById('tab-playlists').style.display = '';

    // Premium badge next to logo
    if (window.__isPremium) document.getElementById('nav-premium-badge').style.display = '';

    // Load profile
    if (!document.getElementById('nav-avatar-wrap')) return;
    const { data: profile } = await sb.from('profiles').select('username,avatar_url').eq('id', session.user.id).single();
    if (!profile) return;
    if (profile.username) document.getElementById('nav-username').textContent = profile.username;
    if (profile.avatar_url) {
      const img = document.getElementById('nav-avatar-img');
      img.src = profile.avatar_url;
      img.style.display = 'block';
      document.getElementById('nav-avatar-initials').style.display = 'none';
    }
  } catch(e) {}
})();
</script>