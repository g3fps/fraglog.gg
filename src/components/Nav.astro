---
const { crumbs = [], user = null } = Astro.props as { crumbs: { label: string; href?: string }[], user: any };
---

<nav>
  <a class="logo" href="/">FragLog<span>.gg</span></a>

  <div style="display:flex;align-items:center;gap:1rem">
    <div class="breadcrumb">
      {crumbs.map((crumb, i) => (
        <>
          {i > 0 && <span class="sep">›</span>}
          {crumb.href
            ? <a class="crumb" href={crumb.href}>{crumb.label}</a>
            : <span class="current">{crumb.label}</span>
          }
        </>
      ))}
    </div>
  </div>

  <div class="nav-search-wrap">
    <input
      type="text"
      id="nav-search"
      class="nav-search-input"
      placeholder="Search players, maps, agents..."
      autocomplete="off"
      oninput="handleNavSearch(this.value)"
      onfocus="if(this.value.trim() && window.location.pathname !== '/search') handleNavSearch(this.value)"
    >
  </div>

  <div class="nav-right" id="nav-right">
    {user ? (
      <>
        <button class="auth-btn" onclick="window.location='/favorites'">♥ Favorites</button>
        <button class="auth-btn" onclick="window.location='/my-vods'">My VODs</button>
        <div class="user-pill">
          <div class="user-avatar">{user.email[0].toUpperCase()}</div>
          {user.email.split("@")[0]}
        </div>
        <button class="auth-btn" onclick="signOut()">Sign Out</button>
      </>
    ) : (
      <>
        <button class="auth-btn" onclick="openAuth()">Sign In</button>
        <button class="auth-btn primary" onclick="openAuth('register')">Sign Up</button>
      </>
    )}
  </div>
</nav>

<script is:inline>
function handleNavSearch(val) {
  if (!val.trim()) return;
  const url = '/search?q=' + encodeURIComponent(val.trim());
  window.location.href = url;
}
</script>