---
import '../styles/global.css';

const { title = 'fraglog.gg — Valorant VOD Library', description = 'Watch Radiant and pro player Valorant gameplay VODs filtered by map and agent. Study the best players in the world on fraglog.gg', ogImage = 'https://media.valorant-api.com/maps/7eaecc1b-4337-bbf6-6ab9-04b8f06b3319/splash.png', canonical = 'https://fraglog.gg', user = null } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="Valorant VODs, Radiant gameplay, pro player POV, Valorant tips, agent guide, map guide">
  <meta name="author" content="fraglog.gg">
  <meta name="robots" content="index, follow">
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
  <link rel="canonical" href={canonical}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <script defer src="https://cdn.vercel-insights.com/v1/script.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" is:inline></script>
</head>
<body>
  <div id="map-bg-layer"></div>
  <slot />

  <!-- Auth Modal -->
  <div class="auth-modal-backdrop" id="auth-modal" onclick="closeAuthModal(event)">
    <div class="auth-modal">
      <h2>FragLog<span style="color:var(--red)">.gg</span></h2>
      <div class="auth-tabs">
        <button class="auth-tab active" onclick="switchTab('login')">Sign In</button>
        <button class="auth-tab" onclick="switchTab('register')">Create Account</button>
      </div>
      <div class="auth-field">
        <label>Email</label>
        <input type="email" id="auth-email" placeholder="you@example.com" autocomplete="email">
      </div>
      <div class="auth-field">
        <label>Password</label>
        <input type="password" id="auth-password" placeholder="••••••••" autocomplete="current-password">
      </div>
      <div class="auth-field" id="confirm-field" style="display:none">
        <label>Confirm Password</label>
        <input type="password" id="auth-confirm" placeholder="••••••••" autocomplete="new-password">
      </div>
      <div class="auth-error" id="auth-error"></div>
      <button class="auth-btn primary" style="width:100%;padding:10px" onclick="submitAuth()">Sign In</button>
    </div>
  </div>

  <!-- Notes Modal -->
  <div class="notes-modal-backdrop" id="notes-modal" onclick="closeNotesModal(event)">
    <div class="notes-modal">
      <div class="notes-modal-header">
        <div>
          <div class="notes-modal-title" id="notes-modal-title"></div>
          <div class="notes-modal-meta" id="notes-modal-meta"></div>
        </div>
        <button class="notes-modal-close" onclick="closeNotesDirect()">✕</button>
      </div>
      <div class="notes-modal-body">
        <div class="notes-admin-box" id="notes-admin-box" style="display:none">
          <div class="notes-admin-label">💡 Creator Note</div>
          <div class="notes-admin-text" id="notes-admin-text"></div>
        </div>
        <div id="notes-ai-box" style="display:none;background:var(--darker);border-left:2px solid #7B8FA1;padding:12px 14px;margin-bottom:12px;border-radius:4px">
          <div style="font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#7B8FA1;margin-bottom:8px">✨ AI Summary</div>
          <div id="notes-ai-text" style="font-size:13px;color:var(--text);line-height:1.7;"></div>
        </div>
        <div class="notes-user-box">
          <div class="notes-user-label">Your Notes</div>
          <textarea class="notes-textarea" id="notes-textarea" placeholder="Write anything — timestamps, things to study, key moments..."></textarea>
        </div>
      </div>
      <div class="notes-modal-footer">
        <span class="notes-char-count" id="notes-char-count">0 characters</span>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <span class="notes-saved-msg" id="notes-saved-msg">✓ Saved</span>
          <button class="notes-save-btn" style="background:var(--surface2);color:var(--muted);border:1px solid var(--border)" onclick="summarizeNotes()" id="notes-summarize-btn">✨ Summarize</button>
          <button class="notes-save-btn" onclick="saveNoteFromModal()">Save Notes</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ user }}>
  window.__initialUser = user;
  </script>

  <script is:inline>
  let _supabase;
  function initSupabase() {
    if (typeof supabase !== 'undefined' && !_supabase) {
      _supabase = supabase.createClient(
        "https://cvdtykmkajmhlxydhzzl.supabase.co",
        "sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi",
        { auth: { persistSession: true, storageKey: 'sb-session', storage: window.localStorage } }
      );
    }
    return _supabase;
  }

  let currentUser = window.__initialUser || null;
  let authMode = "login";
  let userFavorites = [];
  let userNotes = {};
  let userWatched = [];

  async function initAuth() {
    const sb = initSupabase();
    if (!sb) return;
    const { data: { session } } = await sb.auth.getSession();
    if (session?.user) {
      currentUser = session.user;
      await loadUserData();
      document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=3600; SameSite=Lax`;
      document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=604800; SameSite=Lax`;
    }
    renderNav();
    window.__authReady = true;
    if (typeof window.__onAuthReady === 'function') window.__onAuthReady();
  }

  async function loadUserData() {
    if (!currentUser) return;
    const sb = initSupabase();
    const { data: favs } = await sb.from("favorites").select("video_id").eq("user_id", currentUser.id);
    userFavorites = (favs||[]).map(f => f.video_id);
    const { data: notes } = await sb.from("notes").select("video_id, content").eq("user_id", currentUser.id);
    userNotes = {};
    (notes||[]).forEach(n => userNotes[n.video_id] = n.content);
    const { data: watched } = await sb.from("watched").select("video_id").eq("user_id", currentUser.id);
    userWatched = (watched||[]).map(w => w.video_id);
  }

  function renderNav() {
    const nr = document.getElementById("nav-right");
    if (!nr) return;
    if (currentUser) {
      const email = currentUser.email;
      nr.innerHTML = `<button class="auth-btn" onclick="window.location='/favorites'">♥ Favorites</button>
        <button class="auth-btn" onclick="window.location='/my-vods'">My VODs</button>
        <div class="user-pill"><div class="user-avatar">${email[0].toUpperCase()}</div>${email.split("@")[0]}</div>
        <button class="auth-btn" onclick="signOut()">Sign Out</button>`;
    } else {
      nr.innerHTML = `<button class="auth-btn" onclick="openAuth()">Sign In</button>
        <button class="auth-btn primary" onclick="openAuth('register')">Sign Up</button>`;
    }
  }

  function openAuth(mode = "login") {
    authMode = mode;
    switchTab(mode);
    document.getElementById("auth-modal").classList.add("open");
  }
  function closeAuthModalDirect() {
    document.getElementById("auth-modal").classList.remove("open");
    document.getElementById("auth-error").style.display = "none";
    document.getElementById("auth-email").value = "";
    document.getElementById("auth-password").value = "";
    document.getElementById("auth-confirm").value = "";
  }
  function closeAuthModal(e) {
    if (e.target === document.getElementById("auth-modal")) closeAuthModalDirect();
  }
  function switchTab(mode) {
    authMode = mode;
    document.querySelectorAll(".auth-tab").forEach((t,i) => t.classList.toggle("active", mode==="login" ? i===0 : i===1));
    document.getElementById("confirm-field").style.display = mode==="register" ? "block" : "none";
    document.querySelector(".auth-modal .primary").textContent = mode==="login" ? "Sign In" : "Create Account";
    document.getElementById("auth-error").style.display = "none";
  }

  async function submitAuth() {
    const email = document.getElementById("auth-email").value.trim();
    const pass = document.getElementById("auth-password").value;
    const confirm = document.getElementById("auth-confirm").value;
    const errEl = document.getElementById("auth-error");
    const btn = document.querySelector(".auth-modal .primary");
    const sb = initSupabase();

    if (!email || !pass) { errEl.textContent = "Please fill in all fields."; errEl.style.display = "block"; return; }
    btn.textContent = "Please wait..."; btn.disabled = true;

    let error;
    if (authMode === "register") {
      if (pass !== confirm) { errEl.textContent = "Passwords don't match."; errEl.style.display = "block"; btn.textContent = "Create Account"; btn.disabled = false; return; }
      if (pass.length < 6) { errEl.textContent = "Password must be at least 6 characters."; errEl.style.display = "block"; btn.textContent = "Create Account"; btn.disabled = false; return; }
      const { data, error: e } = await sb.auth.signUp({ email, password: pass });
      error = e;
      if (!e) currentUser = data.user;
    } else {
      const { data, error: e } = await sb.auth.signInWithPassword({ email, password: pass });
      error = e;
      if (!e) currentUser = data.user;
    }

    btn.disabled = false;
    btn.textContent = authMode==="login" ? "Sign In" : "Create Account";
    if (error) { errEl.textContent = error.message; errEl.style.display = "block"; return; }

    await loadUserData();
    const session = (await sb.auth.getSession()).data.session;
    if (session) {
      document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=3600; SameSite=Lax`;
      document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=604800; SameSite=Lax`;
    }
    closeAuthModalDirect();
    renderNav();
    if (typeof onAuthChange === 'function') onAuthChange();
  }

  async function signOut() {
    const sb = initSupabase();
    await sb.auth.signOut();
    currentUser = null; userFavorites = []; userNotes = {}; userWatched = [];
    renderNav();
    document.cookie = 'sb-access-token=; path=/; max-age=0';
    document.cookie = 'sb-refresh-token=; path=/; max-age=0';
    window.location.reload();
  }

  function isFav(videoId) { return userFavorites.includes(videoId); }
  function getUserNote(videoId) { return userNotes[videoId] || ""; }
  function isWatched(videoId) { return userWatched.includes(videoId); }

  async function toggleFav(videoId, btn) {
    if (!currentUser) { openAuth(); return; }
    const sb = initSupabase();
    if (isFav(videoId)) {
      userFavorites = userFavorites.filter(id => id !== videoId);
      btn.classList.remove("active"); btn.textContent = "♡ Save";
      await sb.from("favorites").delete().eq("user_id", currentUser.id).eq("video_id", videoId);
    } else {
      userFavorites.push(videoId);
      btn.classList.add("active"); btn.textContent = "♥ Saved";
      await sb.from("favorites").insert({ user_id: currentUser.id, video_id: videoId });
    }
    if (typeof onFavChange === 'function') onFavChange();
  }

  async function toggleWatched(videoId, btn) {
    if (!currentUser) { openAuth(); return; }
    const sb = initSupabase();
    if (isWatched(videoId)) {
      userWatched = userWatched.filter(id => id !== videoId);
      btn.classList.remove("watched"); btn.textContent = "✓ Mark watched";
      await sb.from("watched").delete().eq("user_id", currentUser.id).eq("video_id", videoId);
    } else {
      userWatched.push(videoId);
      btn.classList.add("watched"); btn.textContent = "✓ Watched";
      await sb.from("watched").insert({ user_id: currentUser.id, video_id: videoId });
    }
  }

  async function saveNote(videoId, text) {
    if (!currentUser) return;
    const sb = initSupabase();
    userNotes[videoId] = text;
    await sb.from("notes").upsert(
      { user_id: currentUser.id, video_id: videoId, content: text, updated_at: new Date().toISOString() },
      { onConflict: "user_id,video_id" }
    );
  }

  let currentNoteVideoId = null;

  function openNotes(videoId, title, player, adminNote) {
    currentNoteVideoId = videoId;
    document.getElementById("notes-modal-title").textContent = title;
    document.getElementById("notes-modal-meta").textContent = player;
    const adminBox = document.getElementById("notes-admin-box");
    if (adminNote) { adminBox.style.display = "block"; document.getElementById("notes-admin-text").textContent = adminNote; }
    else { adminBox.style.display = "none"; }
    const ta = document.getElementById("notes-textarea");
    ta.value = getUserNote(videoId);
    document.getElementById("notes-char-count").textContent = ta.value.length + " characters";
    document.getElementById("notes-saved-msg").style.display = "none";
    document.getElementById("notes-ai-box").style.display = "none";
    document.getElementById("notes-ai-text").textContent = "";
    document.getElementById("notes-modal").classList.add("open");
    document.body.style.overflow = "hidden";
    setTimeout(() => ta.focus(), 100);
  }

  async function saveNoteFromModal() {
    const text = document.getElementById("notes-textarea").value;
    await saveNote(currentNoteVideoId, text);
    document.getElementById("notes-saved-msg").style.display = "inline";
    if (typeof onNoteChange === 'function') onNoteChange(currentNoteVideoId);
  }

  async function summarizeNotes() {
    const notes = document.getElementById("notes-textarea").value.trim();
    if (!notes) {
      alert("Write some notes first, then summarize them.");
      return;
    }

    const title = document.getElementById("notes-modal-title").textContent;
    const player = document.getElementById("notes-modal-meta").textContent;
    const btn = document.getElementById("notes-summarize-btn");
    const aiBox = document.getElementById("notes-ai-box");
    const aiText = document.getElementById("notes-ai-text");

    btn.textContent = "✨ Summarizing...";
    btn.disabled = true;
    aiBox.style.display = "block";
    aiText.textContent = "Analyzing your notes...";

    try {
      const response = await fetch("/api/analyze", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ notes, title, player })
      });

      if (!response.ok) {
        throw new Error("API error: " + response.status);
      }

      const data = await response.json();
      const raw = data.text || "No summary generated.";
      const html = raw
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/^#{1,3}\s+(.+)$/gm, '<strong>$1</strong>')
        .replace(/\n\n+/g, '</p><p>')
        .replace(/\n/g, '<br>');
      aiText.innerHTML = '<p>' + html + '</p>';
    } catch (e) {
      aiText.textContent = "Something went wrong. Try again.";
      console.error("Summarize error:", e);
    }

    btn.textContent = "✨ Summarize";
    btn.disabled = false;
  }

  function closeNotesDirect() {
    document.getElementById("notes-modal").classList.remove("open");
    document.body.style.overflow = "";
    document.getElementById("notes-ai-box").style.display = "none";
    document.getElementById("notes-ai-text").textContent = "";
    currentNoteVideoId = null;
  }
  function closeNotesModal(e) {
    if (e.target === document.getElementById("notes-modal")) closeNotesDirect();
  }

  document.addEventListener("DOMContentLoaded", () => {
    const ta = document.getElementById("notes-textarea");
    if (ta) ta.addEventListener("input", () => {
      document.getElementById("notes-char-count").textContent = ta.value.length + " characters";
      document.getElementById("notes-saved-msg").style.display = "none";
    });
    document.getElementById("footer-year").textContent = `© ${new Date().getFullYear()} fraglog.gg — All rights reserved`;
    initAuth().catch(e => console.warn("Auth init failed", e));
  });

  document.addEventListener("keydown", e => {
    if (e.key === "Escape") { closeNotesDirect(); closeAuthModalDirect(); }
  });
  </script>
</body>
</html>