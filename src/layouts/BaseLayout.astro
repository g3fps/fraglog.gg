---
import '../styles/global.css';
import { PREMIUM_ENABLED } from '../lib/premium.js';

const { title = 'fraglog.gg — Valorant VOD Library', description = 'Watch Radiant and pro player Valorant gameplay VODs filtered by map and agent. Study the best players in the world on fraglog.gg', ogImage = '/og-image.png', canonical = 'https://fraglog.gg', user = null, noindex = false, jsonLd = null, preloadImage = null } = Astro.props;
const resolvedOgImage = ogImage?.startsWith('/') ? `https://fraglog.gg${ogImage}` : ogImage;
const TURNSTILE_SITE_KEY = import.meta.env.TURNSTILE_SITE_KEY || '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
  <link rel="preconnect" href="https://img.youtube.com">
  <link rel="preconnect" href="https://i.ytimg.com">
  <link rel="dns-prefetch" href="https://media.valorant-api.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&family=Barlow:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content="Valorant VODs, Radiant gameplay, pro player POV, Valorant tips, agent guide, map guide">
  <meta name="author" content="fraglog.gg">
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={resolvedOgImage}>
  <meta property="og:site_name" content="fraglog.gg">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={resolvedOgImage}>
  <link rel="canonical" href={canonical}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  <script defer src="https://cdn.vercel-insights.com/v1/script.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" is:inline></script>
</head>
<body>
  <script define:vars={{ premiumEnabled: PREMIUM_ENABLED }}>window.__premiumEnabled = premiumEnabled; window.__isPremium = false;</script>
  <div id="map-bg-layer"></div>
  <slot />

  <!-- Coaching Data Sharing Popup -->
  <div class="coaching-share-backdrop" id="coaching-share-modal">
    <div class="coaching-share-modal">
      <div class="coaching-share-icon">🧠</div>
      <h3 class="coaching-share-title">Help improve FragLog's AI Coach</h3>
      <p class="coaching-share-body">Can we anonymously use your VOD notes, coaching responses, and generated gameplans to improve the AI coach for everyone? Your data is never sold or shared with third parties.</p>
      <div class="coaching-share-actions">
        <button class="coaching-share-btn secondary" onclick="setShareCoaching(false)">No thanks</button>
        <button class="coaching-share-btn primary" onclick="setShareCoaching(true)">Yes, share anonymously</button>
      </div>
    </div>
  </div>

  <!-- Auth Modal -->
  <div class="auth-modal-backdrop" id="auth-modal" onclick="closeAuthModal(event)">
    <div class="auth-modal">
      <h2>FragLog<span style="color:var(--red)">.gg</span></h2>
      <div class="auth-tabs">
        <button class="auth-tab active" onclick="switchTab('login')">Sign In</button>
        <button class="auth-tab" onclick="switchTab('register')">Create Account</button>
      </div>
      <form id="auth-form" onsubmit="submitAuth(); return false;">
      <div class="auth-field">
        <label>Email</label>
        <input type="email" id="auth-email" name="username" placeholder="you@example.com" autocomplete="username">
      </div>
      <div class="auth-field">
        <label>Password</label>
        <input type="password" id="auth-password" name="password" placeholder="••••••••" autocomplete="current-password">
      </div>
      <div class="auth-field" id="confirm-field" style="display:none">
        <label>Confirm Password</label>
        <input type="password" id="auth-confirm" name="confirm-password" placeholder="••••••••" autocomplete="new-password">
      </div>
      <div class="auth-error" id="auth-error"></div>
      {TURNSTILE_SITE_KEY && <div id="auth-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark" style="margin-bottom:12px"></div>}
      <button type="submit" class="auth-btn primary" style="width:100%;padding:10px">Sign In</button>
      </form>
    </div>
  </div>

  <!-- Playlist picker (premium add-to-playlist) -->
  <div class="pp-backdrop" id="playlist-picker" onclick="closePlaylistPicker(event)">
    <div class="pp-modal">
      <div class="pp-head">
        <span>Save to playlist</span>
        <button class="pp-close" onclick="closePlaylistPicker()">✕</button>
      </div>
      <div class="pp-list" id="pp-list"></div>
      <div class="pp-new">
        <input type="text" id="pp-new-input" placeholder="New playlist name..." maxlength="100" autocomplete="off">
        <button onclick="createPlaylistAndAdd()">Create</button>
      </div>
      <div class="pp-status" id="pp-status"></div>
    </div>
  </div>

  <!-- Video Modal -->
  <div class="video-modal-backdrop" id="video-modal" onclick="closeVideoModal(event)">
    <div class="video-modal">

      <!-- Left: video + meta -->
      <div class="video-modal-left">
        <div class="video-modal-embed">
          <div id="yt-player"></div>
          <div class="video-modal-embed-fallback" id="vm-fallback">
            <div style="font-size:32px">▶</div>
            <div>Embedding disabled for this video</div>
            <a id="vm-fallback-link" href="" target="_blank" rel="noopener" style="color:var(--red);font-family:'DM Mono',monospace;font-size:11px;letter-spacing:1px">Watch on YouTube →</a>
          </div>
        </div>
        <div class="video-modal-info">
          <div class="video-modal-title" id="vm-title"></div>
          <div class="vm-info-row">
            <div class="vm-info-left">
              <div class="vm-tags" id="vm-tags"></div>
              <a class="video-modal-player" id="vm-player" href=""></a>
              <div class="video-modal-actions" id="vm-actions"></div>
            </div>
            <span class="video-modal-stat" id="vm-date" style="display:none"></span>
          </div>
        </div>
        <div class="vm-marks" id="vm-marks"></div>
      </div>

      <!-- Right: notes -->
      <div class="video-modal-right">
        <div class="video-modal-right-header">
          <div class="video-modal-right-title" id="vm-right-title">Notes</div>
          <div class="vm-panel-tabs" id="vm-panel-tabs" style="display:none">
            <button class="vm-panel-tab active" id="vm-panel-tab-own" onclick="vmSwitchPanelTab('own')">Your Notes</button>
            <button class="vm-panel-tab" id="vm-panel-tab-shared" onclick="vmSwitchPanelTab('shared')">Shared Notes</button>
          </div>
          <div style="display:flex;align-items:center;gap:8px">
            <div class="vm-share-wrap" id="vm-share-wrap" style="display:none">
              <button class="vm-share-toggle" id="vm-share-btn" onclick="vmShareNote()">
                <span class="vm-share-toggle-track"><span class="vm-share-toggle-thumb"></span></span>
                <span class="vm-share-toggle-lbl" id="vm-share-lbl">Private</span>
              </button>
              <div class="vm-share-popup" id="vm-share-popup" style="display:none">
                <div class="vm-share-popup-label">Share link</div>
                <div class="vm-share-popup-row">
                  <span class="vm-share-popup-url" id="vm-share-popup-url"></span>
                  <button class="vm-share-popup-copy" id="vm-share-popup-copy" onclick="vmCopyShareLink()">Copy</button>
                </div>
              </div>
            </div>
            <button class="vm-collapse-btn" id="vm-collapse-btn" onclick="vmToggleVideo()" title="Toggle video">▾</button>
            <button class="vm-size-reset-btn" onclick="vmResetModalSize()" title="Reset size">↺</button>
            <button class="video-modal-close" onclick="closeVideoModalDirect()">✕</button>
          </div>
        </div>
        <div class="video-modal-right-body" id="vm-body"></div>
        <div class="video-modal-right-footer" id="vm-footer" style="display:none">
          <div style="display:flex;align-items:center;gap:10px">
            <span class="vm-char-count" id="vm-char-count">0 characters</span>
            <button class="vm-clear-btn" id="vm-clear-btn" onclick="vmClearNotes()">Clear notes</button>
          </div>
          <div class="vm-footer-right">
            <span class="vm-saved-msg" id="vm-saved-msg">✓ Saved</span>
            <div class="vm-coach-toggle" id="vm-coach-toggle">
              <button id="vm-toggle-own" onclick="setVmCoachMode('own')">Your Gameplay</button>
              <button id="vm-toggle-pro" onclick="setVmCoachMode('pro')">Pro</button>
            </div>
            <span id="vm-coach-usage" style="font-family:'DM Mono',monospace;font-size:10px;color:var(--muted)"></span>
            <button class="vm-save-btn secondary" onclick="vmCoachMe()" id="vm-coach-btn">Coach me</button>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script is:inline define:vars={{ user }}>
  window.__initialUser = user;
  </script>

  <script is:inline>
  let _supabase;
  function initSupabase() {
    if (typeof supabase !== 'undefined' && !_supabase) {
      _supabase = supabase.createClient(
        "https://cvdtykmkajmhlxydhzzl.supabase.co",
        "sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi",
        { auth: { persistSession: true, storageKey: 'sb-session', storage: window.localStorage } }
      );
    }
    return _supabase;
  }

  let currentUser = window.__initialUser || null;
  let authMode = "login";

  // Track where the mouse was pressed so modals only close when a click both
  // STARTS and ENDS on the backdrop. Prevents closing when a text selection
  // that began inside the modal is released outside it.
  window.__mouseDownTarget = null;
  document.addEventListener('mousedown', e => { window.__mouseDownTarget = e.target; }, true);
  window.__backdropClick = (e, modal) => e.target === modal && window.__mouseDownTarget === modal;
  let userFavorites = [];
  let userNotes = {};
  let userCoach = {};
  let userNoteShareIds = {};
  let userNoteVisibility = {};
  let userWatched = [];
  let userTimestamps = {};
  let userDurations = {};
  let userMarks = {}; // { video_id: [{id, seconds, label}] } — VOD clip marks
  let userShareCoaching = null; // null = never asked, true/false = preference set
  let todayCoachingUsed = 0;
  let todayFollowupUsed = 0;
  const COACHING_LIMIT = 3;
  const FOLLOWUP_LIMIT = 5;

  // ── YouTube IFrame API ────────────────────────────────────────
  let ytPlayer = null;
  let ytApiLoaded = false;
  let ytPendingVideoId = null;
  let ytPendingStart = 0;
  let ytTimestampSaveInterval = null;

  // Must be on window before the API script loads
  window.onYouTubeIframeAPIReady = function() {
    ytApiLoaded = true;
    ytPlayer = new YT.Player('yt-player', {
      height: '100%',
      width: '100%',
      playerVars: { autoplay: 1, rel: 0, modestbranding: 1 },
      events: {
        onReady: function(e) {
          if (ytPendingVideoId) {
            e.target.loadVideoById({ videoId: ytPendingVideoId, startSeconds: ytPendingStart });
            ytPendingVideoId = null;
            ytPendingStart = 0;
          }
        },
        onStateChange: function(e) {
          if (e.data === 2 || e.data === 0) {
            saveTimestamp(vmVideoId, Math.floor(e.target.getCurrentTime()));
          }
        },
        onError: function() {
          document.getElementById('yt-player').style.display = 'none';
          document.getElementById('vm-fallback').style.display = 'flex';
        }
      }
    });
  };

  let _twitchEmbed = null;
  let _twitchSdkLoaded = false;

  function secondsToTwitchTime(s) {
    if (!s) return '0h0m0s';
    return `${Math.floor(s/3600)}h${Math.floor((s%3600)/60)}m${s%60}s`;
  }

  function _initTwitchEmbed(twitchId, container, startSeconds) {
    _twitchEmbed = new Twitch.Embed(container, {
      video: twitchId,
      width: '100%',
      height: '100%',
      autoplay: true,
      time: secondsToTwitchTime(startSeconds),
      parent: [window.location.hostname],
    });

    _twitchEmbed.addEventListener(Twitch.Embed.VIDEO_READY, () => {
      const player = _twitchEmbed.getPlayer();
      clearInterval(ytTimestampSaveInterval);
      ytTimestampSaveInterval = setInterval(() => {
        if (!vmVideoId) return;
        const t = Math.floor(player.getCurrentTime());
        const dur = Math.floor(player.getDuration()) || 0;
        if (t > 0) saveTimestamp(vmVideoId, t);
        if (dur > 0) { userDurations[vmVideoId] = dur; applyWatchProgress(); }
      }, 10000);
    });

    _twitchEmbed.addEventListener(Twitch.Embed.VIDEO_PAUSE, () => {
      if (!vmVideoId) return;
      try {
        const t = Math.floor(_twitchEmbed.getPlayer().getCurrentTime());
        if (t > 0) saveTimestamp(vmVideoId, t);
      } catch(e) {}
    });
  }

  function loadTwitchVideo(twitchId, startSeconds) {
    document.getElementById('twitch-player')?.remove();
    _twitchEmbed = null;
    const ytEl = document.getElementById('yt-player');
    ytEl.style.display = 'none';
    document.getElementById('vm-fallback').style.display = 'none';
    clearInterval(ytTimestampSaveInterval);

    const container = document.createElement('div');
    container.id = 'twitch-player';
    container.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%';
    ytEl.parentElement.appendChild(container);

    if (_twitchSdkLoaded) {
      _initTwitchEmbed(twitchId, container, startSeconds);
    } else {
      const tag = document.createElement('script');
      tag.src = 'https://embed.twitch.tv/embed/v1.js';
      tag.onload = () => { _twitchSdkLoaded = true; _initTwitchEmbed(twitchId, container, startSeconds); };
      document.head.appendChild(tag);
    }
  }

  function loadYtVideo(videoId, startSeconds) {
    document.getElementById('yt-player').style.display = 'block';
    document.getElementById('vm-fallback').style.display = 'none';

    if (!ytApiLoaded) {
      // Load API dynamically on first video open — callback already defined above
      ytPendingVideoId = videoId;
      ytPendingStart = startSeconds || 0;
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(tag);
    } else if (ytPlayer && typeof ytPlayer.loadVideoById === 'function') {
      ytPlayer.loadVideoById({ videoId, startSeconds: startSeconds || 0 });
    } else {
      ytPendingVideoId = videoId;
      ytPendingStart = startSeconds || 0;
    }

    clearInterval(ytTimestampSaveInterval);
    ytTimestampSaveInterval = setInterval(() => {
      if (ytPlayer && typeof ytPlayer.getCurrentTime === 'function' && vmVideoId) {
        const t = Math.floor(ytPlayer.getCurrentTime());
        if (t > 0) saveTimestamp(vmVideoId, t);
      }
    }, 10000);
  }

  async function saveTimestamp(videoId, seconds) {
    if (!currentUser || !videoId || !seconds) return;
    userTimestamps[videoId] = seconds;

    // Capture total duration so we can show a progress bar on cards
    let dur = 0;
    if (ytPlayer && typeof ytPlayer.getDuration === 'function') {
      dur = Math.floor(ytPlayer.getDuration()) || 0;
    }
    if (dur > 0) userDurations[videoId] = dur;
    applyWatchProgress();

    const sb = initSupabase();
    const payload = { user_id: currentUser.id, video_id: videoId, resume_at: seconds, updated_at: new Date().toISOString() };
    if (dur > 0) payload.duration = dur;
    const { error } = await sb.from('watched').upsert(payload, { onConflict: 'user_id,video_id' });
    // Resilience: if the `duration` column doesn't exist yet, retry without it
    if (error && payload.duration !== undefined) {
      delete payload.duration;
      await sb.from('watched').upsert(payload, { onConflict: 'user_id,video_id' });
    }
  }

  function getTimestamp(videoId) {
    return userTimestamps[videoId] || 0;
  }

  // ── Watch progress ────────────────────────────────────────
  function getProgressFraction(videoId) {
    const t = userTimestamps[videoId], d = userDurations[videoId];
    if (!t || !d || d <= 0) return 0;
    return Math.max(0, Math.min(1, t / d));
  }

  // Inject/update a progress bar on every visible thumbnail tied to a video id.
  // Works across all card layouts: .video-thumb inside [data-vid], and home .hrc cards.
  function applyWatchProgress(root) {
    root = root || document;
    root.querySelectorAll('[data-vid]').forEach(el => {
      const vid = el.dataset.vid;
      if (!vid) return;
      const thumb = el.matches('.video-thumb, .hrc__thumb')
        ? el
        : el.querySelector('.video-thumb, .hrc__thumb');
      if (!thumb) return;

      const frac = getProgressFraction(vid);
      let bar = thumb.querySelector('.video-progress');
      if (frac <= 0) { if (bar) bar.remove(); return; }

      if (!bar) {
        bar = document.createElement('div');
        bar.className = 'video-progress';
        bar.innerHTML = '<span></span>';
        thumb.appendChild(bar);
      }
      const finished = frac >= 0.9;
      bar.classList.toggle('is-finished', finished);
      bar.firstChild.style.width = (finished ? 100 : Math.round(frac * 100)) + '%';
    });
  }
  window.applyWatchProgress = applyWatchProgress;

  function syncSessionCookies(session) {
    if (session) {
      document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=3600; SameSite=Lax`;
      document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=604800; SameSite=Lax`;
    } else {
      document.cookie = 'sb-access-token=; path=/; max-age=0';
      document.cookie = 'sb-refresh-token=; path=/; max-age=0';
    }
  }

  async function initAuth() {
    try {
      const sb = initSupabase();
      if (!sb) return;

      // Keep cookies in sync whenever Supabase silently refreshes the token
      sb.auth.onAuthStateChange((_event, session) => syncSessionCookies(session));

      const { data: { session } } = await sb.auth.getSession();
      if (session?.user) {
        currentUser = session.user;
        await loadUserData();
        syncSessionCookies(session);
      }
      renderNav();
    } catch(e) {
      console.warn('Auth init failed', e);
      renderNav();
    } finally {
      window.__authReady = true;
      if (typeof window.__onAuthReady === 'function') window.__onAuthReady();
      applyWatchProgress();
    }
  }

  async function loadUserData() {
    if (!currentUser) return;
    const sb = initSupabase();
    const { data: favs } = await sb.from("favorites").select("video_id").eq("user_id", currentUser.id);
    userFavorites = (favs||[]).map(f => f.video_id);
    const { data: notes } = await sb.from("notes").select("video_id, content, coach_text, coach_mode, share_id, visibility").eq("user_id", currentUser.id);
    userNotes = {};
    userCoach = {};
    userNoteShareIds = {};
    userNoteVisibility = {};
    (notes||[]).forEach(n => {
      userNotes[n.video_id] = n.content;
      if (n.coach_text) userCoach[n.video_id] = { text: n.coach_text, mode: n.coach_mode || 'pro' };
      if (n.share_id) userNoteShareIds[n.video_id] = n.share_id;
      userNoteVisibility[n.video_id] = n.visibility || 'private';
    });
    const { data: watched } = await sb.from("watched").select("*").eq("user_id", currentUser.id);
    userWatched = (watched||[]).map(w => w.video_id);
    userTimestamps = {};
    userDurations = {};
    (watched||[]).forEach(w => {
      if (w.resume_at) userTimestamps[w.video_id] = w.resume_at;
      if (w.duration) userDurations[w.video_id] = w.duration;
    });
    const { data: marks } = await sb.from("vod_marks").select("id, video_id, seconds, label").eq("user_id", currentUser.id);
    userMarks = {};
    (marks||[]).forEach(m => { (userMarks[m.video_id] = userMarks[m.video_id] || []).push(m); });

    // Load share_coaching preference
    const { data: profile } = await sb.from('profiles').select('share_coaching').eq('id', currentUser.id).maybeSingle();
    userShareCoaching = profile?.share_coaching ?? null;

    // Premium status (for gating premium-only UI like add-to-playlist)
    try {
      const { data: sub } = await sb.from('subscriptions').select('tier, status, current_period_end').eq('user_id', currentUser.id).maybeSingle();
      window.__isPremium = !!(sub && (sub.tier === 'lifetime'
        || ((sub.tier === 'monthly' || sub.tier === 'yearly') && sub.status === 'active'
            && (!sub.current_period_end || new Date(sub.current_period_end) > new Date()))));
    } catch { window.__isPremium = false; }

    // Load today's coaching usage
    const today = new Date().toISOString().slice(0, 10);
    const { data: usage } = await sb.from('coaching_usage').select('coaching_count, followup_count').eq('user_id', currentUser.id).eq('date', today).maybeSingle();
    todayCoachingUsed = usage?.coaching_count ?? 0;
    todayFollowupUsed = usage?.followup_count ?? 0;
    updateCoachUsageDisplay();
    applyFavButtons();
  }

  function applyFavButtons() {
    document.querySelectorAll('[data-fav-btn]').forEach(btn => {
      const fav = isFav(btn.dataset.favBtn);
      btn.textContent = fav ? '♥' : '♡';
      btn.classList.toggle('fav', fav);
      btn.classList.toggle('active', fav);
    });
  }
  window.applyFavButtons = applyFavButtons;

  async function renderNav() {
    const nr = document.getElementById("nav-right");
    if (!nr) return;
    if (currentUser) {
      const email = currentUser.email;
      const fallbackName = email.split("@")[0];
      let username = fallbackName;
      let avatarUrl = null;
      try {
        const sb = initSupabase();
        const { data: profile } = await sb.from('profiles').select('username,avatar_url').eq('id', currentUser.id).maybeSingle();
        if (profile?.username) username = profile.username;
        if (profile?.avatar_url) avatarUrl = profile.avatar_url;
      } catch(e) {}
      const avatarHtml = avatarUrl
        ? `<img src="${avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block" alt="">`
        : email[0].toUpperCase();
      nr.innerHTML = `<a class="user-pill" href="/settings" style="text-decoration:none"><div class="user-avatar" style="overflow:hidden">${avatarHtml}</div>${username}</a>
        <button class="auth-btn" onclick="signOut()">Sign Out</button>`;
    } else {
      nr.innerHTML = `<button class="auth-btn" onclick="openAuth()">Sign In</button>
        <button class="auth-btn primary" onclick="openAuth('register')">Sign Up</button>`;
    }
  }

  // ── Cloudflare Turnstile (bot check on auth) ──────────────
  let authTurnstileId = null;
  function renderAuthTurnstile(attempt = 0) {
    const el = document.getElementById("auth-turnstile");
    if (!el) return; // not configured (no site key) — nothing to render
    if (!window.turnstile) { if (attempt < 25) setTimeout(() => renderAuthTurnstile(attempt + 1), 150); return; }
    if (authTurnstileId !== null) { try { window.turnstile.reset(authTurnstileId); } catch (e) {} return; }
    try { authTurnstileId = window.turnstile.render(el, { sitekey: el.dataset.sitekey, theme: "dark" }); } catch (e) {}
  }

  function openAuth(mode = "login") {
    authMode = mode;
    switchTab(mode);
    document.getElementById("auth-modal").classList.add("open");
    renderAuthTurnstile();
  }
  function closeAuthModalDirect() {
    document.getElementById("auth-modal").classList.remove("open");
    document.getElementById("auth-error").style.display = "none";
    document.getElementById("auth-email").value = "";
    document.getElementById("auth-password").value = "";
    document.getElementById("auth-confirm").value = "";
  }
  function closeAuthModal(e) {
    if (window.__backdropClick(e, document.getElementById("auth-modal"))) closeAuthModalDirect();
  }
  function switchTab(mode) {
    authMode = mode;
    document.querySelectorAll(".auth-tab").forEach((t,i) => t.classList.toggle("active", mode==="login" ? i===0 : i===1));
    document.getElementById("confirm-field").style.display = mode==="register" ? "block" : "none";
    document.querySelector(".auth-modal .primary").textContent = mode==="login" ? "Sign In" : "Create Account";
    document.getElementById("auth-error").style.display = "none";
  }

  async function submitAuth() {
    const email = document.getElementById("auth-email").value.trim();
    const pass = document.getElementById("auth-password").value;
    const confirm = document.getElementById("auth-confirm").value;
    const errEl = document.getElementById("auth-error");
    const btn = document.querySelector(".auth-modal .primary");
    const sb = initSupabase();
    if (!email || !pass) { errEl.textContent = "Please fill in all fields."; errEl.style.display = "block"; return; }

    // Require the Cloudflare human-check token when the widget is present
    let captchaToken;
    const tsEl = document.getElementById("auth-turnstile");
    if (tsEl && window.turnstile && authTurnstileId !== null) {
      captchaToken = window.turnstile.getResponse(authTurnstileId) || "";
      if (!captchaToken) { errEl.textContent = "Please complete the verification below."; errEl.style.display = "block"; return; }
    }
    const authOpts = captchaToken ? { captchaToken } : {};

    btn.textContent = "Please wait..."; btn.disabled = true;
    let error;
    if (authMode === "register") {
      if (pass !== confirm) { errEl.textContent = "Passwords don't match."; errEl.style.display = "block"; btn.textContent = "Create Account"; btn.disabled = false; return; }
      if (pass.length < 6) { errEl.textContent = "Password must be at least 6 characters."; errEl.style.display = "block"; btn.textContent = "Create Account"; btn.disabled = false; return; }
      const { data, error: e } = await sb.auth.signUp({ email, password: pass, options: authOpts });
      error = e;
      if (!e) {
        // Supabase returns a decoy user with an empty identities array when the
        // email is already registered (anti-enumeration). Treat that as an error
        // so the popup stays open and the user gets feedback.
        if (data.user && Array.isArray(data.user.identities) && data.user.identities.length === 0) {
          error = { message: "An account with this email already exists. Try signing in instead." };
        } else {
          currentUser = data.user;
        }
      }
    } else {
      const { data, error: e } = await sb.auth.signInWithPassword({ email, password: pass, options: authOpts });
      error = e;
      if (!e) currentUser = data.user;
    }
    // Reset the widget so a retry always gets a fresh token (tokens are single-use)
    if (tsEl && window.turnstile && authTurnstileId !== null) { try { window.turnstile.reset(authTurnstileId); } catch (e) {} }
    btn.disabled = false;
    btn.textContent = authMode==="login" ? "Sign In" : "Create Account";
    if (error) { errEl.textContent = error.message; errEl.style.display = "block"; return; }
    await loadUserData();
    syncSessionCookies((await sb.auth.getSession()).data.session);
    closeAuthModalDirect();
    renderNav();
    if (typeof onAuthChange === 'function') onAuthChange();
  }

  async function signOut() {
    const sb = initSupabase();
    await sb.auth.signOut();
    currentUser = null; userFavorites = []; userNotes = {}; userCoach = {}; userNoteShareIds = {}; userNoteVisibility = {}; userWatched = []; userTimestamps = {};
    renderNav();
    document.cookie = 'sb-access-token=; path=/; max-age=0';
    document.cookie = 'sb-refresh-token=; path=/; max-age=0';
    window.location.reload();
  }

  function isFav(videoId) { return userFavorites.includes(videoId); }
  function getUserNote(videoId) { return userNotes[videoId] || ""; }
  function isWatched(videoId) { return userWatched.includes(videoId); }

  async function toggleFav(videoId) {
    if (!currentUser) { openAuth(); return; }
    const sb = initSupabase();
    if (isFav(videoId)) {
      userFavorites = userFavorites.filter(id => id !== videoId);
      await sb.from("favorites").delete().eq("user_id", currentUser.id).eq("video_id", videoId);
    } else {
      userFavorites.push(videoId);
      await sb.from("favorites").insert({ user_id: currentUser.id, video_id: videoId });
    }
    applyFavButtons();
    if (typeof onFavChange === 'function') onFavChange();
  }

  async function toggleWatched(videoId, btn) {
    if (!currentUser) { openAuth(); return; }
    const sb = initSupabase();
    if (isWatched(videoId)) {
      userWatched = userWatched.filter(id => id !== videoId);
      btn.classList.remove("watched"); btn.textContent = "✓ Mark watched";
      await sb.from("watched").delete().eq("user_id", currentUser.id).eq("video_id", videoId);
    } else {
      userWatched.push(videoId);
      btn.classList.add("watched"); btn.textContent = "✓ Watched";
      await sb.from("watched").insert({ user_id: currentUser.id, video_id: videoId });
    }
  }

  async function saveNote(videoId, text) {
    if (!currentUser) return;
    const sb = initSupabase();
    userNotes[videoId] = text;
    await sb.from("notes").upsert(
      { user_id: currentUser.id, video_id: videoId, content: text, updated_at: new Date().toISOString() },
      { onConflict: "user_id,video_id" }
    );
  }

  async function vmClearNotes() {
    if (!vmVideoId || !currentUser) return;
    if (!confirm('Clear all notes for this video?')) return;
    clearTimeout(vmAutosaveTimer);
    vmAutosaveTimer = null;
    vmCurrentNotes = '';
    // Clear every textarea in the notes panel
    document.getElementById('vm-body')?.querySelectorAll('textarea').forEach(t => { t.value = ''; });
    document.getElementById('vm-char-count').textContent = '0 characters';
    await saveNote(vmVideoId, '');
    const msg = document.getElementById('vm-saved-msg');
    if (msg) { msg.style.display = 'inline'; setTimeout(() => { msg.style.display = 'none'; }, 2000); }
  }

  // ── Video Modal ──────────────────────────────────────────────
  let vmVideoId = null;
  let vmCoachMode = 'pro';
  let vmOriginalMode = 'pro';
  let vmAgent = null;
  let vmMap = null;
  let vmCurrentNotes = '';
  let vmAutosaveTimer = null;
  let vmStartingSide = null;
  let vmSharedNote = null;
  let vmPreOpenUrl = null;

  // Ctrl/Cmd+click → open in new tab
  document.addEventListener('click', function(e) {
    if (!e.ctrlKey && !e.metaKey) return;
    const card = e.target.closest('[data-vid]');
    if (!card) return;
    e.preventDefault();
    e.stopPropagation();
    window.open('/watch?v=' + encodeURIComponent(card.dataset.vid), '_blank');
  }, true);
  // Middle-click: prevent autoscroll on mousedown, open new tab on auxclick
  document.addEventListener('mousedown', function(e) {
    if (e.button !== 1) return;
    const card = e.target.closest('[data-vid]');
    if (!card) return;
    e.preventDefault();
  }, true);
  document.addEventListener('auxclick', function(e) {
    if (e.button !== 1) return;
    const card = e.target.closest('[data-vid]');
    if (!card) return;
    e.preventDefault();
    e.stopPropagation();
    window.open('/watch?v=' + encodeURIComponent(card.dataset.vid), '_blank');
  }, true);

  function openVideo(videoId, title, player, opts = {}) {
    clearTimeout(vmAutosaveTimer);
    vmAutosaveTimer = null;
    vmVideoId = videoId;
    vmCoachMode = opts.mode || 'pro';
    vmOriginalMode = opts.mode || 'pro';
    vmAgent = opts.agent || null;
    vmMap = opts.map || null;
    vmCurrentNotes = getUserNote(videoId) || '';

    const twitchId = videoId.startsWith('twitch:') ? videoId.slice(7) : null;
    if (twitchId) {
      loadTwitchVideo(twitchId, getTimestamp(videoId));
      document.getElementById('vm-fallback-link').href = `https://www.twitch.tv/videos/${twitchId}`;
    } else {
      loadYtVideo(videoId, getTimestamp(videoId));
      document.getElementById('vm-fallback-link').href = `https://youtube.com/watch?v=${videoId}`;
    }

    document.getElementById('vm-title').textContent = title;

    const tagsEl = document.getElementById('vm-tags');
    const mapId = opts.mapId || opts.map || null;
    const agentId = opts.agentId || opts.agent || null;
    const mapName = opts.mapName || null;
    const agentName = opts.agentName || null;
    if (mapId || agentId) {
      tagsEl.innerHTML =
        (mapId ? `<a class="video-map-tag" href="/${mapId}">${mapName || mapId}</a>` : '') +
        (agentId ? `<a class="video-agent-tag" href="/agent/${agentId}">${agentName || agentId}</a>` : '');
      tagsEl.style.display = '';
    } else {
      tagsEl.innerHTML = '';
      tagsEl.style.display = 'none';
    }

    const playerEl = document.getElementById('vm-player');
    playerEl.textContent = player;
    playerEl.href = opts.playerHref || '';

    const dateEl = document.getElementById('vm-date');
    if (opts.date) { dateEl.textContent = opts.date; dateEl.style.display = ''; }
    else { dateEl.style.display = 'none'; }

    renderVmActions(videoId);
    renderVmMarks(videoId);
    renderVmNotes(videoId, opts.adminNote, vmCoachMode);
    renderVmShareState(videoId);

    vmPreOpenUrl = location.href;
    history.replaceState(null, '', `/watch?v=${videoId}`);
    document.getElementById('video-modal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function renderVmActions(videoId) {
    const actions = document.getElementById('vm-actions');
    const fav = isFav(videoId);
    let html = `<button class="vm-fav-btn${fav ? ' active' : ''}" data-fav-btn="${videoId}">${fav ? '♥' : '♡'}</button>`;
    if (currentUser) {
      html += `<button class="vm-playlist-btn" onclick="openPlaylistPicker()" title="Add to playlist">+ Playlist</button>`;
    }
    actions.innerHTML = html;
  }

  // ── VOD note sharing ─────────────────────────────────────────
  let vmSharePopupTimer = null;

  function vmHideSharePopup() {
    const popup = document.getElementById('vm-share-popup');
    if (popup) popup.style.display = 'none';
    clearTimeout(vmSharePopupTimer);
  }

  function renderVmShareState(videoId) {
    const vid = videoId || vmVideoId;
    const wrap = document.getElementById('vm-share-wrap');
    const btn = document.getElementById('vm-share-btn');
    if (!wrap || !btn) return;
    if (!currentUser) { wrap.style.display = 'none'; return; }
    wrap.style.display = '';
    const isUnlisted = (userNoteVisibility[vid] || 'private') === 'unlisted';
    btn.classList.toggle('active', isUnlisted);
    const lbl = document.getElementById('vm-share-lbl');
    if (lbl) lbl.textContent = isUnlisted ? 'Share' : 'Private';
    const popup = document.getElementById('vm-share-popup');
    const urlEl = document.getElementById('vm-share-popup-url');
    clearTimeout(vmSharePopupTimer);
    if (popup && urlEl) {
      if (isUnlisted && userNoteShareIds[vid]) {
        urlEl.textContent = `fraglog.gg/watch?v=${vid}&note=${userNoteShareIds[vid]}`;
        popup.style.display = '';
        vmSharePopupTimer = setTimeout(vmHideSharePopup, 4000);
      } else {
        popup.style.display = 'none';
      }
    }
  }

  function vmCopyShareLink() {
    const vid = vmVideoId;
    const shareId = userNoteShareIds[vid];
    if (!shareId) return;
    const url = `https://fraglog.gg/watch?v=${vid}&note=${shareId}`;
    navigator.clipboard.writeText(url).then(() => {
      const btn = document.getElementById('vm-share-popup-copy');
      if (!btn) return;
      btn.textContent = 'Copied!';
      clearTimeout(vmSharePopupTimer);
      vmSharePopupTimer = setTimeout(vmHideSharePopup, 1500);
    });
  }

  async function vmShareNote() {
    if (!currentUser || !vmVideoId) return;
    const currentVis = userNoteVisibility[vmVideoId] || 'private';
    const newVis = currentVis === 'private' ? 'unlisted' : 'private';
    let shareId = userNoteShareIds[vmVideoId];
    if (!shareId && newVis === 'unlisted') shareId = crypto.randomUUID();
    const sb = initSupabase();
    const { error } = await sb.from('notes').upsert(
      { user_id: currentUser.id, video_id: vmVideoId, share_id: shareId, visibility: newVis },
      { onConflict: 'user_id,video_id' }
    );
    if (error) { console.error('note share update failed:', error.message); return; }
    userNoteShareIds[vmVideoId] = shareId;
    userNoteVisibility[vmVideoId] = newVis;
    renderVmShareState(vmVideoId);
    const shareUrl = newVis === 'unlisted'
      ? `/watch?v=${vmVideoId}&note=${shareId}`
      : `/watch?v=${vmVideoId}`;
    history.replaceState(null, '', shareUrl);
  }

  // ── Shared note tab ──────────────────────────────────────────
  function vmInjectSharedNote(noteData) {
    vmSharedNote = noteData;
    const title = document.getElementById('vm-right-title');
    const tabs = document.getElementById('vm-panel-tabs');
    if (title) title.style.display = 'none';
    if (tabs) tabs.style.display = 'flex';
    vmSwitchPanelTab('shared');
  }

  function vmSwitchPanelTab(tab) {
    const ownBtn = document.getElementById('vm-panel-tab-own');
    const sharedBtn = document.getElementById('vm-panel-tab-shared');
    if (ownBtn) ownBtn.classList.toggle('active', tab === 'own');
    if (sharedBtn) sharedBtn.classList.toggle('active', tab === 'shared');
    if (tab === 'own') {
      renderVmNotes(vmVideoId, null, vmCoachMode);
    } else {
      renderVmSharedNote();
    }
  }

  function renderVmSharedNote() {
    const body = document.getElementById('vm-body');
    const footer = document.getElementById('vm-footer');
    if (!body) return;
    footer.style.display = 'none';
    if (!vmSharedNote) { body.innerHTML = '<div class="vm-login-prompt">Shared note not found.</div>'; return; }

    const _esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    let generalNotes = '';
    let rounds = [];
    try {
      const parsed = JSON.parse(vmSharedNote.content || '{}');
      generalNotes = parsed.general || '';
      rounds = (parsed.rounds || []).filter(r => Object.values(r.categories||{}).some(v => String(v).trim()));
    } catch(e) {
      if (vmSharedNote.content && !vmSharedNote.content.startsWith('{')) generalNotes = vmSharedNote.content;
    }
    const coachText = vmSharedNote.coach_text || '';
    const CATS = ['Positioning & Decision Making','Economy','Utility'];

    let html = '<div class="vm-shared-content">';
    if (generalNotes.trim()) {
      html += `<div class="vm-shared-section"><div class="vm-notes-label">General Notes</div><div class="vm-shared-text">${_esc(generalNotes)}</div></div>`;
    }
    if (rounds.length) {
      html += `<div class="vm-shared-section"><div class="vm-notes-label">Round by Round</div>`;
      rounds.forEach(r => {
        const entries = CATS.filter(c => r.categories[c]?.trim()).map(c =>
          `<div class="vm-shared-round-entry"><span class="vm-shared-round-cat">${_esc(c)}</span><span>${_esc(r.categories[c])}</span></div>`
        ).join('');
        html += `<div class="vm-shared-round"><span class="vm-shared-round-num">R${r.round}</span><div class="vm-shared-round-entries">${entries}</div></div>`;
      });
      html += '</div>';
    }
    if (coachText.trim()) {
      html += `<div class="vm-shared-section"><div class="vm-notes-label">AI Coaching</div><div class="vm-shared-coach">${renderCoachHtml(coachText)}</div></div>`;
    }
    if (!generalNotes.trim() && !rounds.length && !coachText.trim()) {
      html += '<div class="vm-login-prompt">No notes content in this share.</div>';
    }
    html += '</div>';
    body.innerHTML = html;
  }

  // ── VOD clip marks (timestamps) ──────────────────────────────
  function fmtMarkTime(s) {
    s = Math.max(0, Math.floor(s || 0));
    const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
    return (h ? h + ':' + String(m).padStart(2, '0') : m) + ':' + String(sec).padStart(2, '0');
  }
  function getPlaybackSeconds() {
    try {
      if (vmVideoId && vmVideoId.startsWith('twitch:')) return Math.floor(_twitchEmbed.getPlayer().getCurrentTime());
      if (ytPlayer && ytPlayer.getCurrentTime) return Math.floor(ytPlayer.getCurrentTime());
    } catch (e) {}
    return 0;
  }
  function seekToMark(s) {
    s = Number(s) || 0;
    try {
      if (vmVideoId && vmVideoId.startsWith('twitch:')) { _twitchEmbed.getPlayer().seek(s); }
      else if (ytPlayer && ytPlayer.seekTo) { ytPlayer.seekTo(s, true); if (ytPlayer.playVideo) ytPlayer.playVideo(); }
    } catch (e) {}
  }
  function renderVmMarks(videoId) {
    const el = document.getElementById('vm-marks');
    if (!el) return;
    if (!currentUser) { el.innerHTML = ''; return; }
    const marks = (userMarks[videoId] || []).slice().sort((a, b) => a.seconds - b.seconds);
    const rows = marks.map(m => `
      <div class="vm-mark-row">
        <button class="vm-mark-jump" onclick="seekToMark(${m.seconds})" title="Jump to ${fmtMarkTime(m.seconds)}">▶ ${fmtMarkTime(m.seconds)}</button>
        <input class="vm-mark-label" data-mark-id="${m.id}" value="${ppEsc(m.label || '')}" placeholder="add a label…" maxlength="80"
          onkeydown="if(event.key==='Enter')this.blur()" onblur="updateMarkLabel('${m.id}', this.value)">
        <button class="vm-mark-del" onclick="deleteMark('${m.id}')" title="Remove">✕</button>
      </div>`).join('');
    el.innerHTML = `
      <div class="vm-marks-head">
        <span class="vm-marks-title">Timestamps</span>
        <button class="vm-mark-add" onclick="addMark()" title="Save the current moment">⊕ Mark this moment</button>
      </div>
      ${rows ? `<div class="vm-marks-list">${rows}</div>`
             : `<div class="vm-marks-empty">No timestamps yet — pause on a moment and hit “Mark this moment”.</div>`}`;
  }
  async function addMark() {
    if (!currentUser) { openAuth(); return; }
    if (!vmVideoId) return;
    const seconds = getPlaybackSeconds();
    const sb = initSupabase();
    const { data, error } = await sb.from('vod_marks')
      .insert({ user_id: currentUser.id, video_id: vmVideoId, seconds, label: '' })
      .select('id, video_id, seconds, label').single();
    if (error || !data) return;
    (userMarks[vmVideoId] = userMarks[vmVideoId] || []).push(data);
    renderVmMarks(vmVideoId);
    const input = document.querySelector(`.vm-mark-label[data-mark-id="${data.id}"]`);
    if (input) input.focus();
  }
  async function updateMarkLabel(id, label) {
    if (!currentUser) return;
    label = (label || '').trim();
    const sb = initSupabase();
    await sb.from('vod_marks').update({ label }).eq('id', id).eq('user_id', currentUser.id);
    for (const vid in userMarks) { const mk = (userMarks[vid] || []).find(m => String(m.id) === String(id)); if (mk) mk.label = label; }
  }
  async function deleteMark(id) {
    if (!currentUser) return;
    const sb = initSupabase();
    await sb.from('vod_marks').delete().eq('id', id).eq('user_id', currentUser.id);
    for (const vid in userMarks) userMarks[vid] = userMarks[vid].filter(m => String(m.id) !== String(id));
    renderVmMarks(vmVideoId);
  }
  window.addMark = addMark;
  window.deleteMark = deleteMark;
  window.seekToMark = seekToMark;
  window.updateMarkLabel = updateMarkLabel;

  // ── Add-to-playlist picker (premium) ─────────────────────────
  let ppPlaylists = [];
  function ppEsc(s) { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  async function openPlaylistPicker() {
    if (!currentUser) { openAuth(); return; }
    // Premium gate: locked only once premium is live and the user isn't premium
    if (window.__premiumEnabled && !window.__isPremium) { window.location.href = '/premium'; return; }
    if (!vmVideoId) return;
    document.getElementById('pp-status').textContent = '';
    document.getElementById('pp-new-input').value = '';
    document.getElementById('playlist-picker').classList.add('open');
    const list = document.getElementById('pp-list');
    list.innerHTML = '<div class="pp-empty">Loading...</div>';
    const sb = initSupabase();
    const { data } = await sb.from('playlists').select('id, title, items').eq('user_id', currentUser.id).order('updated_at', { ascending: false });
    ppPlaylists = data || [];
    renderPickerList();
  }

  function renderPickerList() {
    const list = document.getElementById('pp-list');
    if (!ppPlaylists.length) { list.innerHTML = '<div class="pp-empty">No playlists yet — create one below.</div>'; return; }
    list.innerHTML = ppPlaylists.map((p, i) => {
      const has = (p.items || []).some(it => it.video_id === vmVideoId);
      return `<button class="pp-item${has ? ' pp-item--added' : ''}" onclick="${has ? 'removeFromPlaylistByIndex' : 'addToPlaylistByIndex'}(${i})">
        <span>${ppEsc(p.title || 'Untitled playlist')}</span>
        <span class="pp-item-count">${has ? '✓' : (p.items || []).length}</span>
      </button>`;
    }).join('');
  }

  function ppCurrentItem() {
    return {
      video_id: vmVideoId,
      title: document.getElementById('vm-title').textContent || '',
      player: document.getElementById('vm-player').textContent || '',
      map_id: vmMap || null,
      agent_id: vmAgent || null,
    };
  }

  async function addToPlaylistByIndex(i) {
    const p = ppPlaylists[i];
    if (!p || !vmVideoId) return;
    p.items = p.items || [];
    if (p.items.some(it => it.video_id === vmVideoId)) return;
    p.items.push(ppCurrentItem());
    const sb = initSupabase();
    const { error } = await sb.from('playlists').update({ items: p.items, updated_at: new Date().toISOString() }).eq('id', p.id).eq('user_id', currentUser.id);
    const status = document.getElementById('pp-status');
    if (error) { status.textContent = 'Could not add. Try again.'; return; }
    status.textContent = '✓ Added to ' + (p.title || 'playlist');
    renderPickerList();
  }

  async function removeFromPlaylistByIndex(i) {
    const p = ppPlaylists[i];
    if (!p || !vmVideoId) return;
    p.items = (p.items || []).filter(it => it.video_id !== vmVideoId);
    const sb = initSupabase();
    const { error } = await sb.from('playlists').update({ items: p.items, updated_at: new Date().toISOString() }).eq('id', p.id).eq('user_id', currentUser.id);
    const status = document.getElementById('pp-status');
    if (error) { status.textContent = 'Could not remove. Try again.'; return; }
    status.textContent = 'Removed from ' + (p.title || 'playlist');
    renderPickerList();
  }

  async function createPlaylistAndAdd() {
    if (!vmVideoId || !currentUser) return;
    const name = document.getElementById('pp-new-input').value.trim() || 'New playlist';
    const sb = initSupabase();
    const { data, error } = await sb.from('playlists').insert({ user_id: currentUser.id, title: name, items: [ppCurrentItem()] }).select().single();
    const status = document.getElementById('pp-status');
    if (error) { status.textContent = 'Could not create playlist.'; return; }
    ppPlaylists.unshift(data);
    document.getElementById('pp-new-input').value = '';
    status.textContent = '✓ Created "' + name + '" and added';
    renderPickerList();
  }

  function closePlaylistPicker(e) {
    if (e && !window.__backdropClick(e, document.getElementById('playlist-picker'))) return;
    document.getElementById('playlist-picker').classList.remove('open');
  }

  window.openPlaylistPicker = openPlaylistPicker;
  window.addToPlaylistByIndex = addToPlaylistByIndex;
  window.removeFromPlaylistByIndex = removeFromPlaylistByIndex;
  window.createPlaylistAndAdd = createPlaylistAndAdd;
  window.closePlaylistPicker = closePlaylistPicker;

  function renderVmNotes(videoId, adminNote, mode) {
    const body = document.getElementById('vm-body');
    const footer = document.getElementById('vm-footer');

    if (!currentUser) {
      body.innerHTML = `<div class="vm-login-prompt"><span onclick="openAuth()" style="color:var(--red);cursor:pointer">Sign in</span> to save notes &amp; get AI coaching</div>`;
      footer.style.display = 'none';
      return;
    }

    const saved = userCoach[videoId];
    const hasCoach = !!saved;
    if (hasCoach) vmCoachMode = saved.mode;

    if (hasCoach) {
      renderCoachMode(saved.text, adminNote);
    } else {
      renderNotesMode(videoId, adminNote);
    }

    const toggle = document.getElementById('vm-coach-toggle');
    if (toggle) toggle.style.display = vmOriginalMode === 'own' ? 'flex' : 'none';
    setVmCoachMode(vmCoachMode);
  }

  function renderNotesMode(videoId, adminNote) {
    const body = document.getElementById('vm-body');
    const footer = document.getElementById('vm-footer');
    const vid = videoId || vmVideoId;

    const saved = userCoach[vid];
    const hasCoach = saved && saved.mode === vmCoachMode;

    // Parse saved notes — may be JSON (structured) or plain string (legacy)
    let savedGeneral = '';
    let savedRounds = [];
    const rawSaved = getUserNote(vid);
    if (rawSaved) {
      try {
        const parsed = JSON.parse(rawSaved);
        savedGeneral = parsed.general || '';
        savedRounds = parsed.rounds || [];
        vmStartingSide = parsed.startingSide || null;
      } catch(e) {
        vmStartingSide = null;
        // Legacy plain text — only put in general if it doesn't look like raw JSON
        if (!rawSaved.startsWith('{') && !rawSaved.startsWith('[')) {
          savedGeneral = rawSaved;
        }
      }
    }

    let html = '';
    if (adminNote) {
      html += `<div class="vm-admin-box">
        <div class="vm-admin-label">💡 Creator Note</div>
        <div class="vm-admin-text">${adminNote}</div>
      </div>`;
    }
    if (hasCoach) {
      html += `<button onclick="switchToCoachMode()" style="font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;background:rgba(255,70,85,0.1);border:1px solid rgba(255,70,85,0.3);color:var(--red);padding:6px 12px;border-radius:6px;cursor:pointer;align-self:flex-start;flex-shrink:0">View coaching →</button>`;
    }

    html += `<div class="vm-notes-hint">Your notes coach the same regardless of format — use whatever feels natural.</div>`;

    // Mobile tab bar (hidden on desktop via CSS)
    html += `<div class="vm-notes-tab-bar">
      <button class="active" onclick="vmSwitchTab('general', this)">General</button>
      <button onclick="vmSwitchTab('rounds', this)">Round by Round</button>
    </div>`;

    // Panels wrapper (desktop: both visible with drag divider; mobile: tabs switch active panel)
    html += `<div class="vm-panels-wrapper">`;

    // General notes panel
    html += `<div class="vm-notes-panel active" id="vm-panel-general" style="flex:0 0 50%;min-height:0;overflow:hidden">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;flex-shrink:0">
        <div class="vm-notes-label" style="margin-bottom:0">General Notes</div>
        <div style="display:flex;align-items:center;gap:8px">
          <a class="vm-md-link" href="https://www.markdownguide.org/basic-syntax/" target="_blank" rel="noopener" title="Markdown guide">md?</a>
          <button class="vm-preview-toggle" id="vm-preview-toggle" onclick="vmTogglePreview()">Preview</button>
        </div>
      </div>
      <textarea class="vm-notes-textarea" id="vm-textarea" placeholder="Supports markdown — **bold**, *italic*, ## headings, - lists..." style="flex:1">${savedGeneral}</textarea>
      <div class="vm-notes-preview" id="vm-notes-preview" style="display:none;flex:1"></div>
    </div>`;

    // Drag divider
    html += `<div class="vm-panel-divider" id="vm-panel-divider"><div class="vm-panel-divider-line"></div><button class="vm-panel-divider-reset" onclick="vmResetPanelSplit()" title="Reset split">reset</button><div class="vm-panel-divider-line"></div></div>`;

    // Round-by-round panel
    const ROUND_CATEGORIES = ['Positioning & Decision Making', 'Economy', 'Utility'];
    // Normalize legacy formats to { round, categories: { Cat: notes } }
    const normalizedRounds = savedRounds.map(r => {
      let cats = {};
      if (r.categories) {
        cats = { ...r.categories };
      } else if (r.entries) {
        r.entries.forEach(e => { if (e.category && e.notes) cats[e.category] = e.notes; });
      } else {
        const notes = r.notes || (r.what ? r.what + (r.takeaway ? ' → ' + r.takeaway : '') : '');
        if (r.category && notes) cats[r.category] = notes;
        else if (notes) cats['Positioning'] = notes;
      }
      // Migrate old split categories into combined key
      const pos = cats['Positioning'] || '';
      const dec = cats['Decision Making'] || '';
      if (pos || dec) {
        cats['Positioning & Decision Making'] = [pos, dec].filter(Boolean).join(' | ');
        delete cats['Positioning'];
        delete cats['Decision Making'];
      }
      delete cats['Aim/Mechanics'];
      return { round: r.round, categories: cats };
    });
    // Always start with 24 rounds; merge in any saved notes; append OT rounds beyond 24
    const savedMap = new Map(normalizedRounds.map(r => [r.round, r]));
    const initialRounds = Array.from({length: 24}, (_, i) => savedMap.get(i + 1) || { round: i + 1, categories: {} });
    normalizedRounds.filter(r => r.round > 24).forEach(r => initialRounds.push(r));

    const buildRoundBlock = (roundNum, cats) => {
      const hasNotes = Object.values(cats).some(v => v.trim());
      const numClass = hasNotes ? ' has-notes' : '';
      const defaultCat = ROUND_CATEGORIES.find(c => cats[c]?.trim()) || ROUND_CATEGORIES[0];
      const inputs = ROUND_CATEGORIES.map(c =>
        `<textarea class="vm-round-input${c === defaultCat ? ' active' : ''}" data-round="${roundNum}" data-cat="${c}" placeholder="${c}..." rows="1">${(cats[c]||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</textarea>`
      ).join('');
      return `<div class="vm-round-block" data-round="${roundNum}">
        <div class="vm-round-num${numClass}">${roundNum}</div>
        <select class="vm-round-select has-value" data-round="${roundNum}" onchange="vmSwitchCat(this)">
          ${ROUND_CATEGORIES.map(c => `<option value="${c}"${c === defaultCat ? ' selected' : ''}>${c}</option>`).join('')}
        </select>
        <div class="vm-round-inputs">${inputs}</div>
      </div>`;
    };

    const atkActive = vmStartingSide === 'atk' ? ' active' : '';
    const defActive = vmStartingSide === 'def' ? ' active' : '';
    html += `<div class="vm-notes-panel" id="vm-panel-rounds" style="flex:1;min-height:0">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-shrink:0">
        <div class="vm-notes-label" style="margin-bottom:0">Round by Round</div>
        <div class="vm-side-selector">
          <span class="vm-side-label">Starting:</span>
          <button class="vm-side-btn${atkActive}" id="vm-side-atk" onclick="vmSetSide('atk')">ATK</button>
          <button class="vm-side-btn${defActive}" id="vm-side-def" onclick="vmSetSide('def')">DEF</button>
        </div>
      </div>
      <div class="vm-rounds-scroll" id="vm-rounds-scroll">
        <div id="vm-rounds-body">`;

    initialRounds.forEach(r => {
      if (r.round === 13) html += `<div class="vm-half-divider"><span>HALF</span></div>`;
      if (r.round === 25) html += `<div class="vm-half-divider vm-ot-divider"><span>OT</span></div>`;
      html += buildRoundBlock(r.round, r.categories || {});
    });

    html += `</div>
        <button class="vm-add-round-btn" onclick="vmAddRound()">+ Add OT Round</button>
      </div>
    </div>
    </div>`;

    body.innerHTML = html;
    footer.style.display = 'flex';
    document.getElementById('vm-coach-btn').textContent = 'Coach me';

    const ta = document.getElementById('vm-textarea');
    document.getElementById('vm-char-count').textContent = '';

    const vmTriggerAutosave = () => {
      document.getElementById('vm-saved-msg').style.display = 'none';
      clearTimeout(vmAutosaveTimer);
      vmAutosaveTimer = setTimeout(vmSaveNote, 1500);
    };

    ta.addEventListener('input', vmTriggerAutosave);
    document.getElementById('vm-rounds-body').addEventListener('input', e => {
      const inp = e.target.closest('.vm-round-input');
      if (inp) {
        vmAutoResize(inp);
        const block = inp.closest('.vm-round-block');
        const hasAny = [...block.querySelectorAll('.vm-round-input')].some(i => i.value.trim());
        block.querySelector('.vm-round-num').classList.toggle('has-notes', hasAny);
      }
      vmTriggerAutosave();
    });
    // Resize any pre-filled textareas on load
    document.querySelectorAll('.vm-round-input.active').forEach(vmAutoResize);
    initVmPanelResize();
  }

  let _vmDragCleanup = null;

  function initVmPanelResize() {
    if (_vmDragCleanup) { _vmDragCleanup(); _vmDragCleanup = null; }
    const divider = document.getElementById('vm-panel-divider');
    if (!divider) return;
    const wrapper = document.querySelector('.vm-panels-wrapper');
    const panelG = document.getElementById('vm-panel-general');
    if (!wrapper || !panelG) return;

    const saved = parseFloat(localStorage.getItem('vmPanelSplit') || '0.5');
    if (Math.abs(saved - 0.5) > 0.01) divider.classList.add('is-custom');

    requestAnimationFrame(() => {
      const wh = wrapper.getBoundingClientRect().height;
      const dh = divider.getBoundingClientRect().height;
      if (wh > 0) panelG.style.flex = '0 0 ' + Math.round((wh - dh) * saved) + 'px';
    });

    let dragging = false, startY = 0, startH = 0;

    function onMove(e) {
      if (!dragging) return;
      const wh = wrapper.getBoundingClientRect().height;
      const dh = divider.getBoundingClientRect().height;
      const avail = wh - dh;
      const minH = 80;
      const newH = Math.min(avail - minH, Math.max(minH, startH + (e.clientY - startY)));
      panelG.style.flex = '0 0 ' + newH + 'px';
    }

    function onUp() {
      if (!dragging) return;
      dragging = false;
      divider.classList.remove('is-dragging');
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
      const wh = wrapper.getBoundingClientRect().height;
      const dh = divider.getBoundingClientRect().height;
      const split = panelG.getBoundingClientRect().height / (wh - dh);
      if (Math.abs(split - 0.5) > 0.01) {
        localStorage.setItem('vmPanelSplit', split.toFixed(4));
        divider.classList.add('is-custom');
      } else {
        localStorage.removeItem('vmPanelSplit');
        divider.classList.remove('is-custom');
      }
    }

    divider.addEventListener('mousedown', e => {
      if (e.target.closest('.vm-panel-divider-reset')) return;
      dragging = true;
      startY = e.clientY;
      startH = panelG.getBoundingClientRect().height;
      divider.classList.add('is-dragging');
      document.body.style.cursor = 'row-resize';
      document.body.style.userSelect = 'none';
      e.preventDefault();
    });
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
    _vmDragCleanup = () => {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
    };
  }

  function vmResetPanelSplit() {
    localStorage.removeItem('vmPanelSplit');
    const divider = document.getElementById('vm-panel-divider');
    const wrapper = document.querySelector('.vm-panels-wrapper');
    const panelG = document.getElementById('vm-panel-general');
    if (!divider || !wrapper || !panelG) return;
    divider.classList.remove('is-custom');
    const wh = wrapper.getBoundingClientRect().height;
    const dh = divider.getBoundingClientRect().height;
    panelG.style.flex = '0 0 ' + Math.round((wh - dh) * 0.5) + 'px';
  }

  function vmResetModalSize() {
    const modal = document.querySelector('.video-modal');
    if (modal) { modal.style.width = ''; modal.style.height = ''; }
  }

  function vmTogglePreview() {
    const ta = document.getElementById('vm-textarea');
    const preview = document.getElementById('vm-notes-preview');
    const btn = document.getElementById('vm-preview-toggle');
    if (!ta || !preview || !btn) return;
    const isEdit = ta.style.display !== 'none';
    if (isEdit) {
      preview.innerHTML = vmRenderMarkdown(ta.value);
      ta.style.display = 'none';
      preview.style.display = '';
      btn.textContent = 'Edit';
      btn.classList.add('active');
    } else {
      ta.style.display = '';
      preview.style.display = 'none';
      btn.textContent = 'Preview';
      btn.classList.remove('active');
      ta.focus();
    }
  }

  function vmRenderMarkdown(text) {
    if (!text.trim()) return '<p class="vm-preview-empty">No notes yet.</p>';
    function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function inline(s) {
      return esc(s)
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`(.+?)`/g, '<code>$1</code>');
    }
    let html = '', inUl = false, inOl = false;
    function closeList() {
      if (inUl) { html += '</ul>'; inUl = false; }
      if (inOl) { html += '</ol>'; inOl = false; }
    }
    for (const line of text.split('\n')) {
      if (/^---+$/.test(line.trim())) { closeList(); html += '<hr>'; }
      else if (/^#{1,3} /.test(line)) { closeList(); html += `<h4>${inline(line.replace(/^#+\s*/, ''))}</h4>`; }
      else if (/^[-*] /.test(line)) { if (!inUl) { closeList(); html += '<ul>'; inUl = true; } html += `<li>${inline(line.slice(2))}</li>`; }
      else if (/^\d+\. /.test(line)) { if (!inOl) { closeList(); html += '<ol>'; inOl = true; } html += `<li>${inline(line.replace(/^\d+\. /, ''))}</li>`; }
      else if (!line.trim()) { closeList(); html += '<div class="vm-preview-gap"></div>'; }
      else { closeList(); html += `<p>${inline(line)}</p>`; }
    }
    closeList();
    return html;
  }

  function vmToggleVideo() {
    const left = document.querySelector('.video-modal-left');
    const btn = document.getElementById('vm-collapse-btn');
    if (!left) return;
    const collapsed = left.classList.toggle('vm-video-collapsed');
    btn.textContent = collapsed ? '▴' : '▾';
  }

  function vmSwitchTab(tab, btn) {
    document.querySelectorAll('.vm-notes-tab-bar button').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.vm-notes-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('vm-panel-' + tab)?.classList.add('active');
  }

  function vmAutoResize(el) {
    el.style.height = 'auto';
    el.style.height = el.scrollHeight + 'px';
  }

  function vmSwitchCat(sel) {
    const block = sel.closest('.vm-round-block');
    const cat = sel.value;
    sel.classList.toggle('has-value', cat !== '');
    block.querySelectorAll('.vm-round-input').forEach(inp => {
      inp.classList.toggle('active', inp.dataset.cat === cat);
    });
    const active = cat ? block.querySelector(`.vm-round-input[data-cat="${cat}"]`) : null;
    if (active) { vmAutoResize(active); active.focus(); }
  }

  function vmSetSide(side) {
    vmStartingSide = vmStartingSide === side ? null : side;
    document.getElementById('vm-side-atk')?.classList.toggle('active', vmStartingSide === 'atk');
    document.getElementById('vm-side-def')?.classList.toggle('active', vmStartingSide === 'def');
    document.getElementById('vm-saved-msg').style.display = 'none';
    clearTimeout(vmAutosaveTimer);
    vmAutosaveTimer = setTimeout(vmSaveNote, 1500);
  }

  function vmAddRound() {
    const tbody = document.getElementById('vm-rounds-body');
    if (!tbody) return;
    const blocks = tbody.querySelectorAll('.vm-round-block');
    const nextNum = blocks.length + 1;
    const CATS = ['Positioning & Decision Making', 'Economy', 'Utility'];
    const block = document.createElement('div');
    block.className = 'vm-round-block';
    block.dataset.round = nextNum;
    block.innerHTML = `<div class="vm-round-num">${nextNum}</div>
      <select class="vm-round-select has-value" data-round="${nextNum}" onchange="vmSwitchCat(this)">
        ${CATS.map((c, i) => `<option value="${c}"${i === 0 ? ' selected' : ''}>${c}</option>`).join('')}
      </select>
      <div class="vm-round-inputs">${CATS.map((c, i) =>
        `<textarea class="vm-round-input${i === 0 ? ' active' : ''}" data-round="${nextNum}" data-cat="${c}" placeholder="${c}..." rows="1"></textarea>`
      ).join('')}</div>`;
    if (nextNum === 13) {
      const div = document.createElement('div');
      div.className = 'vm-half-divider';
      div.innerHTML = '<span>HALF</span>';
      tbody.appendChild(div);
    } else if (nextNum === 25) {
      const div = document.createElement('div');
      div.className = 'vm-half-divider vm-ot-divider';
      div.innerHTML = '<span>OT</span>';
      tbody.appendChild(div);
    }
    tbody.appendChild(block);
    block.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function vmCollectRounds() {
    const rounds = [];
    document.querySelectorAll('.vm-round-block').forEach(block => {
      const roundNum = parseInt(block.dataset.round);
      const categories = {};
      block.querySelectorAll('.vm-round-input').forEach(inp => {
        if (inp.value.trim()) categories[inp.dataset.cat] = inp.value;
      });
      if (Object.keys(categories).length) rounds.push({ round: roundNum, categories });
    });
    return rounds;
  }

  function vmCollectNotes() {
    const general = document.getElementById('vm-textarea')?.value || '';
    const rounds = vmCollectRounds();
    if (!rounds.length && !vmStartingSide) return general;
    const obj = { general, rounds };
    if (vmStartingSide) obj.startingSide = vmStartingSide;
    return JSON.stringify(obj);
  }

  function vmRoundSideLabel(roundNum) {
    if (!vmStartingSide) return '';
    const atk = vmStartingSide === 'atk';
    if (roundNum <= 12) return atk ? 'ATK' : 'DEF';
    if (roundNum <= 24) return atk ? 'DEF' : 'ATK';
    return 'OT';
  }

  function vmBuildNotesString() {
    const general = document.getElementById('vm-textarea')?.value.trim() || '';
    const rounds = vmCollectRounds();
    let str = '';
    if (vmStartingSide) {
      const atk = vmStartingSide === 'atk';
      str += `Starting side: ${atk ? 'Attack' : 'Defense'} (rounds 1–12 = ${atk ? 'Attack' : 'Defense'}, rounds 13–24 = ${atk ? 'Defense' : 'Attack'})\n\n`;
    }
    if (general) str += `General observations:\n${general}\n\n`;
    if (rounds.length) {
      str += `Round-by-round notes:\n`;
      rounds.forEach(r => {
        const side = vmRoundSideLabel(r.round);
        const sideTag = side ? ` [${side}]` : '';
        Object.entries(r.categories).forEach(([cat, notes]) => {
          if (notes.trim()) str += `Round ${r.round}${sideTag} [${cat}]: ${notes.trim()}\n`;
        });
      });
    }
    return str.trim();
  }

  function switchToCoachMode() {
    const saved = userCoach[vmVideoId];
    if (saved) renderCoachMode(saved.text, null);
  }

  function renderCoachMode(raw, adminNote) {
    const ta = document.getElementById('vm-textarea');
    if (ta && ta.value.trim()) vmCurrentNotes = ta.value.trim();

    const body = document.getElementById('vm-body');
    const footer = document.getElementById('vm-footer');

    body.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <div class="vm-ai-label" style="margin-bottom:0">AI Coach</div>
        <button onclick="switchToNotesMode()" style="font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;background:none;border:none;color:var(--muted);cursor:pointer;padding:0">← Notes</button>
      </div>
      <div class="vm-ai-text" id="vm-ai-text" style="flex:1;overflow-y:auto;min-height:0">${renderCoachHtml(raw)}</div>
      <div class="vm-followup-box" id="vm-followup-box">
        <input class="vm-followup-input" id="vm-followup-input" placeholder="Ask a follow-up..." onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); vmSendFollowUp(); }">
        <button class="vm-followup-btn" onclick="vmSendFollowUp()" id="vm-followup-btn">→</button>
      </div>`;

    footer.style.display = 'flex';
    document.getElementById('vm-coach-btn').textContent = 'Regenerate';
    document.getElementById('vm-char-count').textContent = '';
    if (!_isAdmin() && todayFollowupUsed >= FOLLOWUP_LIMIT) vmLockFollowUp();
  }

  async function vmSendFollowUp() {
    const input = document.getElementById('vm-followup-input');
    const btn = document.getElementById('vm-followup-btn');
    const question = input?.value?.trim();
    if (!question) return;

    input.value = '';
    btn.disabled = true;
    btn.textContent = '...';

    // Get current coaching text
    const aiText = document.getElementById('vm-ai-text');
    const currentCoaching = userCoach[vmVideoId]?.text || '';

    // Append loading indicator
    const loadingId = 'vm-followup-loading';
    aiText.innerHTML += `<div id="${loadingId}" style="border-top:1px solid var(--border);margin-top:12px;padding-top:12px;color:var(--muted);font-family:'DM Mono',monospace;font-size:11px;letter-spacing:1px">thinking...</div>`;
    aiText.scrollTop = aiText.scrollHeight;

    try {
      const session = (await initSupabase().auth.getSession()).data.session;
      const response = await fetch('/api/analyze', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(session?.access_token ? { 'Authorization': `Bearer ${session.access_token}` } : {})
        },
        body: JSON.stringify({
          notes: vmCurrentNotes || '',
          title: document.getElementById('vm-title').textContent,
          player: document.getElementById('vm-player').textContent,
          mode: 'followup',
          coachMode: vmCoachMode,
          agent: vmAgent,
          map: vmMap,
          coaching: currentCoaching,
          followup: question,
          shareCoaching: userShareCoaching === true
        })
      });
      if (response.status === 401) { openAuth(); return; }
      if (response.status === 429) {
        const err = await response.json().catch(() => ({}));
        todayFollowupUsed = FOLLOWUP_LIMIT;
        const loading = document.getElementById(loadingId);
        if (loading) loading.textContent = err.error || 'Follow-up limit reached for today.';
        vmLockFollowUp();
        return;
      }
      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        throw new Error(err.error || 'API error');
      }
      const data = await response.json();
      const raw = data.text || '';

      todayFollowupUsed++;

      // Persist the follow-up so it survives a reload (it was previously DOM-only)
      if (currentUser && vmVideoId && raw) {
        const prev = (userCoach[vmVideoId] && userCoach[vmVideoId].text) || currentCoaching || '';
        const appended = `${prev}\n\n### Follow-up: ${question}\n\n${raw}`;
        userCoach[vmVideoId] = { text: appended, mode: vmCoachMode };
        try {
          await initSupabase().from('notes').upsert(
            { user_id: currentUser.id, video_id: vmVideoId, coach_text: appended, coach_mode: vmCoachMode, updated_at: new Date().toISOString() },
            { onConflict: 'user_id,video_id' }
          );
        } catch (e) { /* keep the DOM copy even if the save fails */ }
      }

      const loading = document.getElementById(loadingId);
      if (loading) loading.remove();

      aiText.innerHTML += `<div class="vm-followup-response">
        <div class="vm-followup-question">${question}</div>
        <div>${renderCoachHtml(raw)}</div>
      </div>`;
      aiText.scrollTop = aiText.scrollHeight;

      if (!_isAdmin() && todayFollowupUsed >= FOLLOWUP_LIMIT) vmLockFollowUp();
    } catch(e) {
      const loading = document.getElementById(loadingId);
      if (loading) loading.textContent = e.message || 'Something went wrong. Try again.';
    }

    btn.disabled = false;
    btn.textContent = '→';
  }

  function vmLockFollowUp() {
    const input = document.getElementById('vm-followup-input');
    const btn = document.getElementById('vm-followup-btn');
    if (input) { input.disabled = true; input.placeholder = `Follow-up limit reached (${FOLLOWUP_LIMIT}/day)`; }
    if (btn) { btn.disabled = true; }
  }

  function switchToNotesMode() {
    renderNotesMode(vmVideoId, null);
    const toggle = document.getElementById('vm-coach-toggle');
    if (toggle) toggle.style.display = vmOriginalMode === 'own' ? 'flex' : 'none';
  }

  const _ADMIN_EMAILS = ['g3holliday@proton.me', 'kettlejalapenochips@gmail.com'];
  function _isAdmin() { return !!(currentUser?.email && _ADMIN_EMAILS.includes(currentUser.email)); }

  function updateCoachUsageDisplay() {
    const el = document.getElementById('vm-coach-usage');
    if (!el || !currentUser) { if (el) el.textContent = ''; return; }
    if (_isAdmin()) { el.textContent = '∞'; el.style.color = 'var(--muted)'; return; }
    const remaining = COACHING_LIMIT - todayCoachingUsed;
    el.textContent = `${remaining}/${COACHING_LIMIT} left`;
    el.style.color = remaining === 0 ? 'var(--red)' : 'var(--muted)';
  }


  function setVmCoachMode(mode) {
    vmCoachMode = mode;
    const ownBtn = document.getElementById('vm-toggle-own');
    const proBtn = document.getElementById('vm-toggle-pro');
    if (ownBtn) {
      ownBtn.style.background = mode === 'own' ? 'var(--red)' : 'var(--surface2)';
      ownBtn.style.color = mode === 'own' ? '#fff' : 'var(--muted)';
    }
    if (proBtn) {
      proBtn.style.background = mode === 'pro' ? 'var(--red)' : 'var(--surface2)';
      proBtn.style.color = mode === 'pro' ? '#fff' : 'var(--muted)';
    }
  }

  function renderCoachHtml(raw) {
    const escaped = raw
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

    const withHeaders = escaped
      .replace(/\*\*(.+?)\*\*/g, (_, t) => `<strong>${t}</strong>`)
      .replace(/^#{1,3}\s+(.+)$/gm, (_, t) => `<div class="vm-coach-section-header">${t}</div>`)
      .replace(/(https?:\/\/[^\s<]+)/g, (url) => `<a href="${url}" target="_blank" rel="noopener" style="color:var(--red);text-decoration:underline;word-break:break-all">${url}</a>`);

    const withBreaks = withHeaders
      .replace(/\n\n+/g, '</p><p>')
      .replace(/\n/g, '<br>');

    return '<p>' + withBreaks + '</p>';
  }

  async function vmSaveNote() {
    if (!vmVideoId) return;
    const data = vmCollectNotes();
    if (!data) return;
    // Don't wipe existing notes by saving a structurally empty object
    if (typeof data === 'string' && data.startsWith('{')) {
      try {
        const parsed = JSON.parse(data);
        const hasContent = parsed.general?.trim() || parsed.rounds?.some(r => Object.values(r.categories || {}).some(v => v?.trim()));
        if (!hasContent) return;
      } catch { /* fall through and save */ }
    }
    await saveNote(vmVideoId, data);
    document.getElementById('vm-saved-msg').style.display = 'inline';
    if (typeof onNoteChange === 'function') onNoteChange(vmVideoId);
  }

  async function setShareCoaching(value) {
    document.getElementById('coaching-share-modal').classList.remove('open');
    userShareCoaching = value;
    if (!currentUser) return;
    const sb = initSupabase();
    await sb.from('profiles').upsert(
      { id: currentUser.id, share_coaching: value, updated_at: new Date().toISOString() },
      { onConflict: 'id' }
    );
    // If they just accepted, proceed with the pending coach request
    if (value && window.__pendingCoachFn) {
      window.__pendingCoachFn();
      window.__pendingCoachFn = null;
    }
  }

  async function vmCoachMe() {
    if (!currentUser) { openAuth(); return; }
    const ta = document.getElementById('vm-textarea');
    const notes = ta ? vmBuildNotesString() : vmCurrentNotes;
    if (!notes) { alert('Write some notes first.'); return; }
    vmCurrentNotes = notes;

    // Show popup if user hasn't been asked yet
    if (userShareCoaching === null) {
      window.__pendingCoachFn = () => _runCoachMe(notes);
      document.getElementById('coaching-share-modal').classList.add('open');
      return;
    }

    _runCoachMe(notes);
  }

  async function _runCoachMe(notes) {

    // Also save current notes before coaching
    const saveData = vmCollectNotes();
    if (saveData) await saveNote(vmVideoId, saveData);

    const btn = document.getElementById('vm-coach-btn');
    const body = document.getElementById('vm-body');

    btn.textContent = 'Coaching...';
    btn.disabled = true;

    body.innerHTML = `<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;gap:12px;color:var(--muted)">
      <div style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase">Analyzing your notes...</div>
    </div>`;

    try {
      const session = (await initSupabase().auth.getSession()).data.session;
      const response = await fetch('/api/analyze', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(session?.access_token ? { 'Authorization': `Bearer ${session.access_token}` } : {})
        },
        body: JSON.stringify({
          notes: notes,
          title: document.getElementById('vm-title').textContent,
          player: document.getElementById('vm-player').textContent,
          mode: vmCoachMode,
          agent: vmAgent,
          map: vmMap,
          shareCoaching: userShareCoaching === true
        })
      });
      if (response.status === 401) { openAuth(); return; }
      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        throw new Error(err.error || 'API error');
      }
      const data = await response.json();
      const raw = data.text || '';

      if (currentUser && vmVideoId) {
        userCoach[vmVideoId] = { text: raw, mode: vmCoachMode };
        const sb = initSupabase();
        await sb.from('notes').upsert(
          { user_id: currentUser.id, video_id: vmVideoId, coach_text: raw, coach_mode: vmCoachMode, updated_at: new Date().toISOString() },
          { onConflict: 'user_id,video_id' }
        );
      }

      todayCoachingUsed++;
      updateCoachUsageDisplay();
      renderCoachMode(raw, null);
    } catch(e) {
      body.innerHTML = `<div style="padding:1rem;color:var(--red);font-family:'DM Mono',monospace;font-size:12px">${e.message || 'Something went wrong. Try again.'}</div>`;
    }

    btn.textContent = 'Regenerate';
    btn.disabled = false;
  }

  function closeVideoModalDirect() {
    if (vmVideoId?.startsWith('twitch:')) {
      if (_twitchEmbed) {
        try {
          const t = Math.floor(_twitchEmbed.getPlayer().getCurrentTime());
          if (t > 0) saveTimestamp(vmVideoId, t);
        } catch(e) {}
        _twitchEmbed = null;
      }
      document.getElementById('twitch-player')?.remove();
    } else if (ytPlayer && typeof ytPlayer.getCurrentTime === 'function' && vmVideoId) {
      const t = Math.floor(ytPlayer.getCurrentTime());
      if (t > 0) saveTimestamp(vmVideoId, t);
      ytPlayer.stopVideo();
    }
    clearInterval(ytTimestampSaveInterval);
    document.getElementById('video-modal').classList.remove('open');
    document.body.style.overflow = '';
    history.replaceState(null, '', vmPreOpenUrl || '/');
    clearTimeout(vmAutosaveTimer);
    vmVideoId = null;
    vmAgent = null;
    vmMap = null;
    vmCurrentNotes = '';
    vmSharedNote = null;
    const _rt = document.getElementById('vm-right-title');
    const _pt = document.getElementById('vm-panel-tabs');
    if (_rt) _rt.style.display = '';
    if (_pt) _pt.style.display = 'none';
    const _to = document.getElementById('vm-panel-tab-own');
    if (_to) _to.classList.add('active');
    const _ts = document.getElementById('vm-panel-tab-shared');
    if (_ts) _ts.classList.remove('active');
  }

  function closeVideoModal(e) {
    if (window.__backdropClick(e, document.getElementById('video-modal'))) closeVideoModalDirect();
  }

  function openNotes(videoId, title, player, adminNote, mode = 'pro') {
    openVideo(videoId, title, player, { adminNote, mode });
  }

  document.addEventListener('click', e => {
    const wrap = document.getElementById('vm-share-wrap');
    const popup = document.getElementById('vm-share-popup');
    if (popup && popup.style.display !== 'none' && wrap && !wrap.contains(e.target)) {
      vmHideSharePopup();
    }
  });

  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("footer-year").textContent = `© ${new Date().getFullYear()} fraglog.gg — All rights reserved`;
    initAuth().catch(e => console.warn("Auth init failed", e));
    const _vp = new URLSearchParams(location.search).get('v');
    if (_vp) {
      const _vc = document.querySelector(`[data-vid="${CSS.escape(_vp)}"]`);
      if (_vc) _vc.click();
    }
    const _np = new URLSearchParams(location.search).get('note');
    if (_np) {
      initSupabase().from('notes')
        .select('video_id,content,coach_text,coach_mode')
        .eq('share_id', _np)
        .eq('visibility', 'unlisted')
        .maybeSingle()
        .then(({ data }) => { if (data) vmInjectSharedNote(data); });
    }
  });

  document.addEventListener("keydown", e => {
    if (e.key === "Escape") { closeVideoModalDirect(); closeAuthModalDirect(); }
  });

  document.addEventListener("click", e => {
    const btn = e.target.closest('[data-fav-btn]');
    if (!btn) return;
    toggleFav(btn.dataset.favBtn);
  });
  </script>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer is:inline></script>
</body>
