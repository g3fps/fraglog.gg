---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const sbAccess = Astro.cookies.get('sb-access-token')?.value;
const sbRefresh = Astro.cookies.get('sb-refresh-token')?.value;

let user = null;
if (sbAccess && sbRefresh) {
  const { createClient } = await import('@supabase/supabase-js');
  const sb = createClient(
    'https://cvdtykmkajmhlxydhzzl.supabase.co',
    'sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi'
  );
  const { data: { user: u } } = await sb.auth.setSession({ access_token: sbAccess, refresh_token: sbRefresh });
  user = u;
}
---

<BaseLayout title="Util — fraglog.gg" user={user}>
  <Nav crumbs={[{ label: "Util" }]} user={user} />

  <div class="util-coming-soon">
    <div class="util-cs-inner">
      <div class="util-cs-eyebrow">Coming Soon</div>
      <h1 class="util-cs-title">Util Library</h1>
      <p class="util-cs-sub">Smokes, walls, mollies and more — organized by agent and map. Currently being rebuilt. Check back soon.</p>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
.util-coming-soon {
  min-height: calc(100vh - 160px);
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 2;
}
.util-cs-inner {
  text-align: center; max-width: 480px; padding: 2rem;
}
.util-cs-eyebrow {
  font-family: 'DM Mono', monospace; font-size: 11px;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--red); margin-bottom: 12px;
}
.util-cs-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 56px; font-weight: 800; letter-spacing: 1px;
  text-transform: uppercase; color: var(--text);
  line-height: 1; margin-bottom: 16px;
}
.util-cs-sub {
  font-size: 15px; color: var(--muted); line-height: 1.6;
}
</style>