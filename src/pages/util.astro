---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getSessionUser } from '../lib/auth.js';

const { user } = await getSessionUser(Astro.cookies);

const ALLOWED_EMAILS = [
  'g3holliday@proton.me',
  'kettlejalapenochips@gmail.com',
];

const isAllowed = user && ALLOWED_EMAILS.includes(user.email ?? '');
---

<BaseLayout
  title="Valorant Lineup Library — fraglog.gg"
  description="Browse Valorant lineups by map and agent on fraglog.gg. Smokes, mollies, and utility setups from Radiant players."
  canonical="https://fraglog.gg/util/"
  user={user}>
  <Nav crumbs={[{ label: "Util" }]} user={user} />

  {isAllowed ? (
  <main class="coaching-main">
    <div class="page-content">
      <div class="coaching-header">
        <div class="header-eyebrow">Util</div>
        <h1 class="header-title">Find Your Lineup</h1>
        <p class="header-sub">Search smokes, walls, mollies and more by agent or map.</p>
      </div>

      <div class="search-wrap">
        <div class="search-box">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" id="search-input" class="search-input" placeholder="e.g. viper bind a site smokes..." autocomplete="off">
          <button class="search-btn" id="search-btn" onclick="searchLineups()"><span id="search-btn-text">Search</span></button>
        </div>
      </div>

      <div id="results-section" style="display:none">
        <div class="results-meta" id="results-meta"></div>
        <div class="results-grid" id="results-grid"></div>
      </div>

      <div class="empty-state" id="empty-state" style="display:none">
        <div class="empty-icon">📭</div>
        <div class="empty-title">No lineups yet</div>
        <div class="empty-sub">Check back soon as more lineups get added.</div>
      </div>

      <div class="no-results" id="no-results" style="display:none">
        <div class="empty-icon">📭</div>
        <div class="empty-title">No lineups found</div>
        <div class="empty-sub">Try different search terms or check back as more lineups get added.</div>
      </div>
    </div>
  </main>
  ) : (
  <main class="coaching-main">
    <div class="page-content">
      <div class="util-coming-soon">
        <div class="util-coming-soon-eyebrow">Coming Soon</div>
        <h1 class="util-coming-soon-title">Util Library</h1>
        <p class="util-coming-soon-sub">A searchable lineup library for every agent and map — smokes, walls, mollies, and more.</p>
      </div>
    </div>
  </main>
  )}

  <Footer />
</BaseLayout>

<div class="lineup-modal-backdrop" id="lineup-modal" onclick="closeModal(event)">
  <div class="lineup-modal">
    <div class="lineup-modal-header">
      <div>
        <div class="lineup-modal-title" id="modal-title"></div>
        <div class="lineup-modal-meta" id="modal-meta"></div>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="lineup-modal-body">
      <div class="modal-map-side">
        <div class="modal-minimap-wrap">
          <img id="modal-minimap" src="" alt="" class="modal-minimap-img">
          <canvas id="modal-canvas" class="modal-canvas"></canvas>
        </div>
      </div>
      <div class="modal-video-side">
        <div class="modal-video-wrap">
          <iframe id="modal-video" src="" frameborder="0" allowfullscreen class="modal-video"></iframe>
        </div>
        <div class="modal-description" id="modal-description"></div>
        <div class="modal-tags" id="modal-tags"></div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
let allLineups = [];
let currentLineup = null;

async function loadLineups() {
  const { createClient } = supabase;
  const sb = createClient('https://cvdtykmkajmhlxydhzzl.supabase.co','sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi');
  const { data, error } = await sb.from('lineups').select('*').order('created_at', { ascending: false });
  if (error || !data) { document.getElementById('empty-state').style.display = 'block'; return; }
  allLineups = data;
  if (!allLineups.length) { document.getElementById('empty-state').style.display = 'block'; return; }
  showResults(allLineups, '');
}

async function searchLineups() {
  const btn = document.getElementById('search-btn');
  const btnText = document.getElementById('search-btn-text');
  const query = document.getElementById('search-input').value.trim();
  btn.disabled = true; btnText.textContent = 'Searching...';
  if (!query) { showResults(allLineups, ''); btn.disabled = false; btnText.textContent = 'Search'; return; }
  const words = query.toLowerCase().split(/\s+/).filter(Boolean);
  const matchedLineups = allLineups.filter(l => {
    const haystack = [l.agent, l.map, l.util_type, l.description, l.title, ...(l.tags || [])].join(' ').toLowerCase();
    return words.every(w => haystack.includes(w));
  }).slice(0, 50);
  btn.disabled = false; btnText.textContent = 'Search';
  showResults(matchedLineups, query);
}

function showResults(lineups, query) {
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('no-results').style.display = 'none';
  if (!lineups.length) {
    document.getElementById('results-section').style.display = 'none';
    document.getElementById('no-results').style.display = 'block';
    return;
  }
  document.getElementById('results-section').style.display = 'block';
  document.getElementById('results-meta').textContent = query ? `${lineups.length} lineup${lineups.length!==1?'s':''} found for "${query}"` : `${lineups.length} lineup${lineups.length!==1?'s':''}`;
  const grid = document.getElementById('results-grid');
  grid.innerHTML = lineups.map((l, i) => `
    <div class="lineup-card" onclick="openLineup(${allLineups.indexOf(l)})">
      <div class="card-minimap-wrap" id="wrap-${i}">
        <img class="card-minimap-img" src="/maps/${l.map}-${l.side||'attack'}.png" alt="${l.map}" data-sx="${l.stand_x}" data-sy="${l.stand_y}" data-lx="${l.land_x}" data-ly="${l.land_y}" data-agent="${l.agent}" data-slot="${l.ability_slot||''}" data-wall-end-x="${l.wall_end_x||''}" data-wall-end-y="${l.wall_end_y||''}" data-util="${(l.util_type||'').replace(/"/g,'&quot;')}" data-idx="${i}" onload="onCardImgLoad(this)">
        <canvas class="card-canvas" id="card-canvas-${i}"></canvas>
      </div>
      <div class="card-info">
        <div class="card-agent-row">
          <img class="card-agent-img" src="/agents/busts/${l.agent}.png" alt="${l.agent}">
          <span class="card-agent-name">${l.agent}</span>
          <span class="card-map">${l.map}</span>
        </div>
        ${l.title ? `<div class="lineup-card-title">${l.title}</div>` : ''}
        <div class="card-desc">${l.description}</div>
      </div>
    </div>
  `).join('');
}

function onCardImgLoad(imgEl) {
  const i = imgEl.dataset.idx;
  setTimeout(() => {
    const canvas = document.getElementById(`card-canvas-${i}`);
    if (canvas) drawMarkers(canvas, imgEl, imgEl.dataset.sx, imgEl.dataset.sy, imgEl.dataset.lx, imgEl.dataset.ly, imgEl.dataset.agent, imgEl.dataset.slot, 30, imgEl.dataset.wallEndX || null, imgEl.dataset.wallEndY || null, imgEl.dataset.util);
  }, 100);
}

function drawMarkers(canvas, imgEl, sx, sy, lx, ly, agent, slot, size, wallEndX, wallEndY, utilType) {
  const wrap = canvas.parentElement;
  const wrapW = wrap.offsetWidth;
  const wrapH = wrap.offsetHeight;
  const dpr = window.devicePixelRatio || 1;
  canvas.width = wrapW * dpr; canvas.height = wrapH * dpr;
  const ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, wrapW, wrapH);
  const padding = 0; // map coords are a clean fraction of the contain-fit image (must match lineup-admin)
  const imgNaturalW = imgEl.naturalWidth, imgNaturalH = imgEl.naturalHeight;
  const availW = wrapW - padding * 2, availH = wrapH - padding * 2;
  const scale = Math.min(availW / imgNaturalW, availH / imgNaturalH);
  const renderedW = imgNaturalW * scale, renderedH = imgNaturalH * scale;
  const ox = (wrapW - renderedW) / 2, oy = (wrapH - renderedH) / 2;
  const toX = x => ox + x * renderedW, toY = y => oy + y * renderedH;

  const big = size >= 40;
  const sX = toX(sx), sY = toY(sy);
  const hasLand = lx != null && ly != null && !(Number(lx) === Number(sx) && Number(ly) === Number(sy));
  const lX = toX(lx), lY = toY(ly);
  const isWall = wallEndX != null && wallEndY != null;
  const RED = '#FF4655', GREEN = '#43E07A';

  // connecting line with a dark halo for legibility on the map
  function line(x1, y1, x2, y2, color, w) {
    ctx.save(); ctx.lineCap = 'round';
    ctx.strokeStyle = 'rgba(0,0,0,0.55)'; ctx.lineWidth = w + 3;
    ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
    ctx.strokeStyle = color; ctx.lineWidth = w;
    ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
    ctx.restore();
  }

  // circular image marker: dark disc + soft drop-shadow, image clipped inside
  function disc(x, y, radius, src, bg, pad) {
    ctx.save();
    ctx.beginPath(); ctx.arc(x, y, radius, 0, Math.PI * 2);
    ctx.fillStyle = bg || '#0e131c';
    ctx.shadowColor = 'rgba(0,0,0,0.8)'; ctx.shadowBlur = big ? 10 : 7; ctx.shadowOffsetY = 2;
    ctx.fill();
    ctx.restore();
    const img = new Image();
    img.onload = () => {
      ctx.save();
      ctx.beginPath(); ctx.arc(x, y, radius - 1, 0, Math.PI * 2); ctx.clip();
      const d = (radius - 1 - (pad || 0)) * 2;
      ctx.drawImage(img, x - d / 2, y - d / 2, d, d);
      ctx.restore();
    };
    img.src = src;
  }

  // 1) throw line: stand -> land
  if (hasLand) line(sX, sY, lX, lY, 'rgba(255,255,255,0.9)', big ? 2.6 : 1.8);

  // 2) wall line: land -> wallEnd
  if (isWall) line(lX, lY, toX(wallEndX), toY(wallEndY), GREEN, big ? 5 : 3.5);

  // 3) ability icon at the landing spot (real ability image) — skipped for walls
  if (slot && lx != null && ly != null && !isWall) {
    disc(lX, lY, big ? 15 : 11, `/abilities/${agent}/${slot}.png`, '#15171f', big ? 3 : 2);
  } else if (hasLand && !isWall) {
    ctx.save();
    ctx.beginPath(); ctx.arc(lX, lY, big ? 5 : 3.5, 0, Math.PI * 2);
    ctx.fillStyle = RED; ctx.shadowColor = 'rgba(0,0,0,0.7)'; ctx.shadowBlur = 4; ctx.fill();
    ctx.restore();
  }

  // 4) agent portrait at the stand spot (real agent image) — drawn last, on top
  disc(sX, sY, big ? 19 : 14, `/agents/busts/${agent}.png`);
}

function openLineup(index) {
  currentLineup = allLineups[index];
  const l = currentLineup;
  document.getElementById('modal-title').textContent = l.title || `${l.agent.charAt(0).toUpperCase()+l.agent.slice(1)} — ${l.map.charAt(0).toUpperCase()+l.map.slice(1)}`;
  document.getElementById('modal-meta').textContent = `${l.util_type} · ${l.side||'attack'}`;
  document.getElementById('modal-description').textContent = l.description;
  document.getElementById('modal-tags').innerHTML = (l.tags||[]).map(t=>`<span class="modal-tag">${t}</span>`).join('');
  const minimapImg = document.getElementById('modal-minimap');
  minimapImg.onload = () => {
    const canvas = document.getElementById('modal-canvas');
    drawMarkers(canvas, minimapImg, l.stand_x, l.stand_y, l.land_x, l.land_y, l.agent, l.ability_slot||'', 46, l.wall_end_x||null, l.wall_end_y||null, l.util_type);
  };
  minimapImg.src = `/maps/${l.map}-${l.side||'attack'}.png`;
  document.getElementById('modal-video').src = `https://www.youtube.com/embed/${l.youtube_id}?autoplay=1`;
  document.getElementById('lineup-modal').classList.add('open');
}

function closeModal(e) {
  if (e && !window.__backdropClick(e, document.getElementById('lineup-modal'))) return;
  document.getElementById('lineup-modal').classList.remove('open');
  document.getElementById('modal-video').src = '';
}

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('search-input').addEventListener('keydown', e => { if(e.key==='Enter') searchLineups(); });
  loadLineups();
});
</script>
