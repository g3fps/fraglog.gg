---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { MAPS, AGENTS } from '../data/data.js';
import { PREMIUM_ENABLED, FREE_LIMITS } from '../lib/premium.js';
import { getSessionPremium } from '../lib/auth.js';

const { user, isPremium } = await getSessionPremium(Astro.cookies);
const premiumGate = { premiumEnabled: PREMIUM_ENABLED, isPremium, freeVodCap: FREE_LIMITS.vodUploads };
---
<BaseLayout title="My VODs — fraglog.gg" description="Your personal Valorant VOD collection on FragLog.gg" user={user}>
  <Nav crumbs={[{ label: 'ALL MAPS', href: '/' }, { label: 'MY VODS' }]} user={user} />
  <div class="page-content">
    <div class="hero">
      <div class="hero-eyebrow">Personal Collection</div>
      <div class="hero-title">My VODs</div>
      <div class="hero-sub">Track your own gameplay footage by map and agent</div>
    </div>

    <div class="myvods-form">
      <div class="section-label" style="margin-bottom:0">Add a VOD</div>
      <div class="myvods-fields">
        <div class="myvods-field">
          <label>Video URL</label>
          <input type="text" id="mv-url" placeholder="YouTube or Twitch VOD URL..." oninput="mvExtractId()">
          <div class="mv-id-display" id="mv-id-display"></div>
        </div>
        <div class="myvods-row">
          <div class="myvods-field">
            <label>Map</label>
            <select id="mv-map">
              <option value="">Select map...</option>
              {MAPS.map(m => <option value={m.id}>{m.name}</option>)}
            </select>
          </div>
          <div class="myvods-field">
            <label>Agent</label>
            <select id="mv-agent">
              <option value="">Select agent...</option>
              <optgroup label="Duelists">
                {AGENTS.filter(a=>a.role==="Duelist").map(a => <option value={a.id}>{a.name}</option>)}
              </optgroup>
              <optgroup label="Controllers">
                {AGENTS.filter(a=>a.role==="Controller").map(a => <option value={a.id}>{a.name}</option>)}
              </optgroup>
              <optgroup label="Sentinels">
                {AGENTS.filter(a=>a.role==="Sentinel").map(a => <option value={a.id}>{a.name}</option>)}
              </optgroup>
              <optgroup label="Initiators">
                {AGENTS.filter(a=>a.role==="Initiator").map(a => <option value={a.id}>{a.name}</option>)}
              </optgroup>
            </select>
          </div>
          <div class="myvods-field">
            <label>Title</label>
            <input type="text" id="mv-title" placeholder="e.g. My Jett Ascent game">
          </div>
        </div>
      </div>
      <button class="auth-btn primary" onclick="submitMyVod()" id="mv-submit-btn" style="margin-top:1rem">+ Add to My VODs</button>
      <div class="mv-error" id="mv-error"></div>
    </div>

    <div class="section-label" style="margin-top:2rem">Your collection</div>
    <div class="video-grid" id="mv-grid">
      <div class="empty"><strong>Loading...</strong></div>
    </div>
  </div>
  <Footer />
</BaseLayout>

<script type="application/json" id="mv-premium-gate" is:inline set:html={JSON.stringify(premiumGate)}></script>

<script is:inline>
let mvVideoId = "";
let myVodCount = 0;
let myVods = [];
const mvGate = JSON.parse(document.getElementById('mv-premium-gate')?.textContent || '{}');

function mvExtractId() {
  const url = document.getElementById("mv-url").value.trim();
  const display = document.getElementById("mv-id-display");
  const ytMatch = url.match(/(?:v=|youtu\.be\/|embed\/|live\/)([a-zA-Z0-9_-]{11})/);
  const twitchMatch = url.match(/twitch\.tv\/videos\/(\d+)/);
  if (ytMatch) {
    mvVideoId = ytMatch[1];
    display.textContent = "YouTube · " + mvVideoId;
  } else if (twitchMatch) {
    mvVideoId = "twitch:" + twitchMatch[1];
    display.textContent = "Twitch · " + twitchMatch[1];
  } else {
    mvVideoId = "";
    display.textContent = url.length > 5 ? "No video ID found" : "";
  }
}

async function submitMyVod() {
  if (!currentUser) { openAuth(); return; }
  const mapId = document.getElementById("mv-map").value;
  const agentId = document.getElementById("mv-agent").value;
  const title = document.getElementById("mv-title").value.trim();
  const errEl = document.getElementById("mv-error");
  const btn = document.getElementById("mv-submit-btn");

  errEl.textContent = "";
  if (!mvVideoId) { errEl.textContent = "Paste a valid YouTube or Twitch VOD URL."; return; }
  if (!mapId) { errEl.textContent = "Select a map."; return; }
  if (!agentId) { errEl.textContent = "Select an agent."; return; }
  if (!title) { errEl.textContent = "Enter a title."; return; }

  // Free accounts are capped on VOD uploads (premium = unlimited)
  if (mvGate.premiumEnabled && !mvGate.isPremium && myVodCount >= (mvGate.freeVodCap || 10)) {
    errEl.innerHTML = `Free accounts can store up to ${mvGate.freeVodCap} VODs. <a href="/premium" style="color:var(--red);text-decoration:underline">Go Premium</a> for unlimited uploads.`;
    return;
  }

  btn.textContent = "Saving..."; btn.disabled = true;

  const sb = initSupabase();
  const { error } = await sb.from("user_vods").insert({
    user_id: currentUser.id,
    video_id: mvVideoId,
    title, map_id: mapId, agent_id: agentId,
    date: new Date().toISOString().split("T")[0],
  });

  btn.textContent = "+ Add to My VODs"; btn.disabled = false;
  if (error) { errEl.textContent = "Error saving VOD: " + error.message; return; }

  document.getElementById("mv-url").value = "";
  document.getElementById("mv-id-display").textContent = "";
  document.getElementById("mv-map").value = "";
  document.getElementById("mv-agent").value = "";
  document.getElementById("mv-title").value = "";
  mvVideoId = "";
  renderMyVods();
}

async function renderMyVods() {
  const grid = document.getElementById("mv-grid");
  if (!currentUser) {
    grid.innerHTML = '<div class="empty"><strong>Not signed in</strong>Sign in to build your private VOD collection<button class="auth-btn primary empty-cta" onclick="openAuth()">Sign In</button></div>';
    return;
  }

  grid.innerHTML = '<div class="empty">Loading...</div>';
  const sb = initSupabase();
  const { data, error } = await sb.from("user_vods").select("*").eq("user_id", currentUser.id).order("created_at", { ascending: false });

  if (error || !data) { grid.innerHTML = '<div class="empty"><strong>Error loading VODs</strong></div>'; return; }
  myVodCount = data.length;
  myVods = data;
  if (!data.length) {
    grid.innerHTML = '<div class="empty"><strong>No VODs yet</strong>Paste a YouTube URL above to add your first one</div>';
    return;
  }

  const MAPS_DATA = [
    {id:"ascent",name:"Ascent"},{id:"bind",name:"Bind"},{id:"haven",name:"Haven"},
    {id:"split",name:"Split"},{id:"fracture",name:"Fracture"},{id:"pearl",name:"Pearl"},
    {id:"icebox",name:"Icebox"},{id:"breeze",name:"Breeze"},{id:"lotus",name:"Lotus"},
    {id:"sunset",name:"Sunset"},{id:"abyss",name:"Abyss"},{id:"corrode",name:"Corrode"},
  ];
  const AGENTS_DATA = [
    {id:"jett",name:"Jett"},{id:"reyna",name:"Reyna"},{id:"raze",name:"Raze"},{id:"neon",name:"Neon"},
    {id:"phoenix",name:"Phoenix"},{id:"yoru",name:"Yoru"},{id:"iso",name:"Iso"},{id:"waylay",name:"Waylay"},
    {id:"omen",name:"Omen"},{id:"viper",name:"Viper"},{id:"brimstone",name:"Brimstone"},{id:"astra",name:"Astra"},
    {id:"harbor",name:"Harbor"},{id:"clove",name:"Clove"},{id:"miks",name:"Miks"},
    {id:"sage",name:"Sage"},{id:"cypher",name:"Cypher"},{id:"killjoy",name:"Killjoy"},{id:"chamber",name:"Chamber"},
    {id:"deadlock",name:"Deadlock"},{id:"vyse",name:"Vyse"},{id:"veto",name:"Veto"},
    {id:"sova",name:"Sova"},{id:"breach",name:"Breach"},{id:"skye",name:"Skye"},{id:"kayo",name:"KAY/O"},
    {id:"fade",name:"Fade"},{id:"gekko",name:"Gekko"},{id:"tejo",name:"Tejo"},
  ];
  const mapName = id => MAPS_DATA.find(m=>m.id===id)?.name || id;
  const agentName = id => AGENTS_DATA.find(a=>a.id===id)?.name || id;

  grid.innerHTML = data.map(v => {
    const isTwitch = v.video_id.startsWith('twitch:');
    const thumb = isTwitch
      ? `<div class="mv-twitch-thumb"><svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg><span>Twitch VOD</span></div>`
      : `<img src="https://img.youtube.com/vi/${v.video_id}/mqdefault.jpg" alt="${v.title}" loading="lazy">`;
    return `
    <div class="video-card" data-id="${v.id}" data-vid="${v.video_id}" data-title="${v.title.replace(/"/g, '&quot;')}" style="cursor:pointer">
      <a class="card-link" href="/watch?v=${encodeURIComponent(v.video_id)}" tabindex="-1" aria-hidden="true"></a>
      <div class="video-thumb">
        ${thumb}
        <div class="play-overlay"><div class="play-icon"><div class="play-tri"></div></div></div>
      </div>
      <div class="video-info">
        <div class="video-tag-row">
          <span class="video-map-tag">${mapName(v.map_id)}</span>
          <span class="video-agent-tag">${agentName(v.agent_id)}</span>
        </div>
        <a class="card-link video-title" href="/watch?v=${encodeURIComponent(v.video_id)}">${v.title}</a>
        <div class="video-meta-row">
          <span class="video-date">${v.date ? new Date(v.date).toLocaleDateString('en-US',{month:'short',year:'numeric'}) : ''}</span>
          <div class="mv-card-actions">
            <button class="mv-edit-btn" onclick="event.stopPropagation();editMyVod('${v.id}')">Edit</button>
            <button class="mv-delete-btn" onclick="event.stopPropagation();deleteMyVod('${v.id}')">✕ Remove</button>
          </div>
        </div>
      </div>
    </div>
  `; }).join("");

  grid.onclick = e => {
    const card = e.target.closest('.video-card[data-vid]');
    if (!card || e.target.closest('button') || card.classList.contains('mv-editing') || e.target.closest('input,select,.mv-edit')) return;
    const a = e.target.closest('a');
    if (a && !a.classList.contains('card-link')) return;
    if (a) e.preventDefault();
    openVideo(card.dataset.vid, card.dataset.title, 'Me', { mode: 'own' });
  };
  if (window.applyWatchProgress) window.applyWatchProgress();

  // Fetch real thumbnails for Twitch VODs
  data.filter(v => v.video_id.startsWith('twitch:')).forEach(async v => {
    const twitchId = v.video_id.slice(7);
    try {
      const res = await fetch(`/api/twitch-thumb?id=${twitchId}`);
      const json = await res.json();
      if (json.url) {
        const placeholder = grid.querySelector(`[data-vid="${v.video_id}"] .mv-twitch-thumb`);
        if (placeholder) {
          const img = document.createElement('img');
          img.src = json.url;
          img.alt = v.title;
          img.loading = 'lazy';
          placeholder.replaceWith(img);
        }
      }
    } catch(e) {}
  });
}

async function deleteMyVod(id) {
  if (!confirm("Remove this VOD from your collection? Your notes will also be deleted.")) return;
  const sb = initSupabase();
  const { data: vod } = await sb.from("user_vods").select("video_id").eq("id", id).eq("user_id", currentUser.id).single();
  if (vod?.video_id) {
    await sb.from("notes").delete().eq("user_id", currentUser.id).eq("video_id", vod.video_id);
    await sb.from("watched").delete().eq("user_id", currentUser.id).eq("video_id", vod.video_id);
    delete userNotes[vod.video_id];
    delete userCoach[vod.video_id];
  }
  await sb.from("user_vods").delete().eq("id", id).eq("user_id", currentUser.id);
  renderMyVods();
}

function editMyVod(id) {
  const vod = myVods.find(v => String(v.id) === String(id));
  const card = document.querySelector(`.video-card[data-id="${id}"]`);
  if (!vod || !card) return;
  const mapOptions = document.getElementById('mv-map').innerHTML;
  const agentOptions = document.getElementById('mv-agent').innerHTML;
  card.classList.add('mv-editing');
  card.style.cursor = 'default';
  card.innerHTML = `
    <div class="mv-edit">
      <label>Title</label>
      <input type="text" class="mv-edit-title" value="${(vod.title || '').replace(/"/g, '&quot;')}">
      <div class="mv-edit-row">
        <div class="mv-edit-field">
          <label>Map</label>
          <select class="mv-edit-map">${mapOptions}</select>
        </div>
        <div class="mv-edit-field">
          <label>Agent</label>
          <select class="mv-edit-agent">${agentOptions}</select>
        </div>
      </div>
      <div class="mv-edit-actions">
        <button class="auth-btn primary" onclick="saveMyVodEdit('${id}')">Save</button>
        <button class="auth-btn" onclick="renderMyVods()">Cancel</button>
      </div>
      <div class="mv-error mv-edit-err"></div>
    </div>`;
  card.querySelector('.mv-edit-map').value = vod.map_id || '';
  card.querySelector('.mv-edit-agent').value = vod.agent_id || '';
}

async function saveMyVodEdit(id) {
  const card = document.querySelector(`.video-card[data-id="${id}"]`);
  if (!card) return;
  const title = card.querySelector('.mv-edit-title').value.trim();
  const mapId = card.querySelector('.mv-edit-map').value;
  const agentId = card.querySelector('.mv-edit-agent').value;
  const err = card.querySelector('.mv-edit-err');
  err.textContent = '';
  if (!title) { err.textContent = 'Enter a title.'; return; }
  if (!mapId) { err.textContent = 'Select a map.'; return; }
  if (!agentId) { err.textContent = 'Select an agent.'; return; }
  const sb = initSupabase();
  const { error } = await sb.from('user_vods').update({ title, map_id: mapId, agent_id: agentId }).eq('id', id).eq('user_id', currentUser.id);
  if (error) { err.textContent = 'Error saving: ' + error.message; return; }
  renderMyVods();
}

function onAuthChange() { renderMyVods(); }

window.__onAuthReady = renderMyVods;
if (window.__authReady) renderMyVods();
</script>