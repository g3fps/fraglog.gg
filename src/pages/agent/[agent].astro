---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { AGENTS, formatDate } from '../../data/data.js';
import { getAllVods } from '../../lib/vods.js';
import { getSessionUser } from '../../lib/auth.js';

const { user } = await getSessionUser(Astro.cookies);

const { agent } = Astro.params;
const agentData = (AGENTS as any[]).find((a: any) => a.id === agent);
if (!agentData) return Astro.redirect('/');

const agentVods = (await getAllVods()).filter((v: any) => v.agentId === agent);
if (!agentVods.length) return Astro.redirect('/');

const title = `${agentData.name} VODs — fraglog.gg`;
const description = `Watch all ${agentVods.length} ${agentData.name} VODs on FragLog.gg — filtered by map.`;
---
<BaseLayout title={title} description={description} user={user}>
  <Nav crumbs={[{ label: 'ALL MAPS', href: '/' }, { label: agentData.name.toUpperCase() }]} user={user} />
  <div class="page-content">
    <div class="videos-header">
      <div>
        <div class="hero-eyebrow">{agentData.role}</div>
        <div class="videos-title">{agentData.name}</div>
        <div class="hero-sub">{agentVods.length} VOD{agentVods.length !== 1 ? 's' : ''} across all maps</div>
      </div>
    </div>

    <div class="video-grid" id="video-grid">
      {agentVods.map((v: any) => (
        <div class="video-card"
          data-vid={v.id}
          data-title={v.title}
          data-player={v.player}
          data-date={v.date ? formatDate(v.date) : ''}
          data-note={v.note || ''}
          data-map-id={v.mapId}
          data-map-name={v.mapName}
          data-agent-id={v.agentId}
          data-agent-name={v.agentName}
          style="cursor:pointer"
        >
          <div class="video-thumb">
            <img src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`} alt={v.title} loading="lazy" />
            <div class="play-overlay">
              <div class="play-icon"><div class="play-tri"></div></div>
            </div>
            <div class="vc-actions">
              <button class="vc-action-btn" data-fav-btn={v.id} title="Save to favorites">♡</button>
            </div>
          </div>
          <div class="video-info">
            <div class="video-tag-row">
              <a class="video-map-tag" href={`/${v.mapId}`}>{v.mapName}</a>
              <a class="video-agent-tag" href={`/${v.mapId}/${v.agentId}`}>{v.agentName}</a>
            </div>
            <div class="video-title">{v.title}</div>
            <div class="video-meta-row">
              <span class="video-player">{v.player}</span>
              {v.date && <span class="video-date">{formatDate(v.date)}</span>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <Footer />
</BaseLayout>

<script is:inline>
document.addEventListener('click', function(e) {
  const card = e.target.closest('.video-card[data-vid]');
  if (!card) return;
  if (e.target.closest('button') || e.target.closest('a')) return;
  openVideo(card.dataset.vid, card.dataset.title, card.dataset.player, {
    date: card.dataset.date || '',
    adminNote: card.dataset.note || '',
    mapId: card.dataset.mapId || '',
    mapName: card.dataset.mapName || '',
    agentId: card.dataset.agentId || '',
    agentName: card.dataset.agentName || ''
  });
});

function onFavChange() {}
window.__onAuthReady = function() {};
if (window.__authReady) {}
</script>
