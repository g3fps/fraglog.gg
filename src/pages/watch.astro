---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getSessionUser } from '../lib/auth.js';
import { getAllVods } from '../data/data.js';

const { user } = await getSessionUser(Astro.cookies);
const videoId = Astro.url.searchParams.get('v') || '';
if (!videoId) return Astro.redirect('/');

const vod = getAllVods().find(v => v.id === videoId) ?? null;
---
<BaseLayout title="Watch — fraglog.gg" user={user}>
  <Nav crumbs={[{ label: 'ALL MAPS', href: '/' }, { label: 'WATCH' }]} user={user} />
  <Footer />
</BaseLayout>

<script is:inline define:vars={{ vod, videoId }}>
document.addEventListener('DOMContentLoaded', () => {
  if (vod) {
    openVideo(vod.id, vod.title, vod.player, {
      agentId: vod.agentId,
      mapId: vod.mapId,
      agentName: vod.agentName,
      mapName: vod.mapName,
      date: vod.date || ''
    });
  } else {
    openVideo(videoId, '', '', {});
  }
});
</script>
