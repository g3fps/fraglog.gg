---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const sbAccess = Astro.cookies.get('sb-access-token')?.value;
const sbRefresh = Astro.cookies.get('sb-refresh-token')?.value;

let user = null;
if (sbAccess && sbRefresh) {
  const { createClient } = await import('@supabase/supabase-js');
  const sb = createClient(
    'https://cvdtykmkajmhlxydhzzl.supabase.co',
    'sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi'
  );
  const { data: { user: u } } = await sb.auth.setSession({ access_token: sbAccess, refresh_token: sbRefresh });
  user = u;
}

if (!user) return Astro.redirect('/');
---

<BaseLayout title="Settings — fraglog.gg" user={user}>
  <Nav crumbs={[{ label: 'Settings' }]} user={user} />

  <main class="settings-main">
    <div class="settings-container">
      <h1 class="settings-title">Account Settings</h1>

      <!-- Avatar + username header -->
      <div class="profile-header">
        <div class="avatar-wrap">
          <div class="avatar-preview" id="avatar-preview">
            <img id="avatar-img" src="" alt="">
            <span id="avatar-initials"></span>
          </div>
          <label class="avatar-upload-btn" for="avatar-input">Change Photo</label>
          <input type="file" id="avatar-input" accept="image/jpeg,image/png,image/webp,image/gif" hidden>
          <div class="upload-status" id="upload-status"></div>
        </div>
        <div class="profile-header-info">
          <div class="profile-display-name" id="profile-display-name">Loading...</div>
          <div class="profile-email" id="profile-email"></div>
        </div>
      </div>

      <!-- Profile section -->
      <div class="settings-section">
        <div class="settings-section-title">Profile</div>
        <div class="settings-card">
          <div class="settings-field">
            <label>Username</label>
            <input type="text" id="inp-username" placeholder="your_username" maxlength="30">
            <div class="field-hint">Letters, numbers, and underscores only. Shown in the nav.</div>
          </div>
          <button class="btn-save" id="btn-save-profile" onclick="saveProfile()">Save Profile</button>
          <div class="save-status" id="profile-status"></div>
        </div>
      </div>

      <!-- Email section -->
      <div class="settings-section">
        <div class="settings-section-title">Email</div>
        <div class="settings-card">
          <div class="settings-field">
            <label>New Email</label>
            <input type="email" id="inp-email" placeholder="new@email.com">
          </div>
          <button class="btn-save" onclick="changeEmail()">Update Email</button>
          <div class="save-status" id="email-status"></div>
        </div>
      </div>

      <!-- Password section -->
      <div class="settings-section">
        <div class="settings-section-title">Password</div>
        <div class="settings-card">
          <div class="settings-field">
            <label>New Password</label>
            <input type="password" id="inp-password" placeholder="••••••••" autocomplete="new-password">
          </div>
          <div class="settings-field">
            <label>Confirm Password</label>
            <input type="password" id="inp-password-confirm" placeholder="••••••••" autocomplete="new-password">
          </div>
          <button class="btn-save" onclick="changePassword()">Update Password</button>
          <div class="save-status" id="password-status"></div>
        </div>
      </div>

      <!-- AI Coaching Data -->
      <div class="settings-section">
        <div class="settings-section-title">AI Coaching Data</div>
        <div class="settings-card">
          <div class="toggle-row">
            <div class="toggle-info">
              <div class="toggle-label">Share coaching data anonymously</div>
              <div class="toggle-desc">Help improve FragLog's AI coach by sharing your VOD notes, coaching responses, and generated gameplans. Your data is never sold or shared with third parties.</div>
            </div>
            <button class="toggle-btn" id="share-coaching-toggle" onclick="toggleShareCoaching()">
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
            </button>
          </div>
          <div class="save-status" id="coaching-share-status"></div>
        </div>
      </div>

      <!-- Premium -->
      <div class="settings-section">
        <div class="settings-section-title">Premium</div>
        <div class="settings-card">
          <div class="toggle-row">
            <div class="toggle-info">
              <div class="toggle-label" id="premium-plan-label">Free plan</div>
              <div class="toggle-desc" id="premium-plan-desc">Upgrade for higher AI limits, cross-note AI, unlimited VOD uploads, and playlists.</div>
            </div>
            <a class="btn-save" id="premium-action" href="/premium">Upgrade</a>
          </div>
        </div>
      </div>

      <!-- Danger zone -->
      <div class="settings-section">
        <div class="settings-section-title danger">Danger Zone</div>
        <div class="settings-card danger-card">
          <div class="danger-description">Permanently delete your account and all associated data. This cannot be undone.</div>
          <button class="btn-danger" onclick="confirmDelete()">Delete Account</button>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>


<script is:inline>
const STORAGE_URL = `https://cvdtykmkajmhlxydhzzl.supabase.co/storage/v1/object/public/avatars/`;

// Reuse BaseLayout's Supabase instance
function getSb() { return initSupabase(); }

let settingsUser = null;

function setStatus(id, msg, color = '#6BCF6B') {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = msg;
  el.style.color = color;
  setTimeout(() => { el.textContent = ''; }, 3000);
}

function setUploadStatus(msg, color = 'var(--muted)') {
  const el = document.getElementById('upload-status');
  el.textContent = msg;
  el.style.color = color;
}

async function init() {
  const sb = getSb();
  const { data: { user } } = await sb.auth.getUser();
  if (!user) { window.location.href = '/'; return; }
  settingsUser = user;

  document.getElementById('profile-email').textContent = settingsUser.email;

  // Load profile — use maybeSingle to avoid 406 when no row exists yet
  const { data: profile } = await sb.from('profiles').select('*').eq('id', settingsUser.id).maybeSingle();
  const username = profile?.username || settingsUser.email.split('@')[0];
  const avatarUrl = profile?.avatar_url || null;

  document.getElementById('inp-username').value = profile?.username || '';
  document.getElementById('profile-display-name').textContent = username;

  // Load share_coaching preference
  const shareCoachingToggle = document.getElementById('share-coaching-toggle');
  if (profile?.share_coaching === true) shareCoachingToggle.classList.add('active');

  // Set avatar
  if (avatarUrl) {
    const img = document.getElementById('avatar-img');
    img.src = avatarUrl;
    img.style.display = 'block';
    document.getElementById('avatar-initials').style.display = 'none';
  } else {
    document.getElementById('avatar-initials').textContent = username[0].toUpperCase();
  }

  // Premium status
  try {
    const { data: sub } = await sb.from('subscriptions').select('tier, status, current_period_end').eq('user_id', settingsUser.id).maybeSingle();
    const active = sub && (sub.tier === 'lifetime'
      || ((sub.tier === 'monthly' || sub.tier === 'yearly') && sub.status === 'active'
          && (!sub.current_period_end || new Date(sub.current_period_end) > new Date())));
    if (active) {
      const label = document.getElementById('premium-plan-label');
      const desc = document.getElementById('premium-plan-desc');
      const action = document.getElementById('premium-action');
      const tierName = sub.tier === 'lifetime' ? 'Lifetime' : sub.tier === 'yearly' ? 'Yearly' : 'Monthly';
      label.textContent = `Premium — ${tierName}`;
      desc.textContent = sub.tier === 'lifetime'
        ? 'You have lifetime access. Thank you for supporting fraglog!'
        : (sub.current_period_end ? 'Renews ' + new Date(sub.current_period_end).toLocaleDateString() : 'Active.');
      action.textContent = 'Manage';
      action.removeAttribute('href');
      action.style.cursor = 'pointer';
      action.onclick = manageBilling;
    }
  } catch {}
}

async function manageBilling() {
  const sb = getSb();
  const { data: { session } } = await sb.auth.getSession();
  if (!session) return;
  const res = await fetch('/api/billing-portal', { method: 'POST', headers: { 'Authorization': 'Bearer ' + session.access_token } });
  const data = await res.json().catch(() => ({}));
  if (res.ok && data.url) window.location.href = data.url;
  else alert(data.error || 'Could not open billing portal.');
}

async function saveProfile() {
  const username = document.getElementById('inp-username').value.trim();
  if (!username) { setStatus('profile-status', 'Username cannot be empty.', 'var(--red)'); return; }
  if (!/^[a-zA-Z0-9_]+$/.test(username)) { setStatus('profile-status', 'Only letters, numbers, underscores.', 'var(--red)'); return; }

  const btn = document.getElementById('btn-save-profile');
  btn.disabled = true; btn.textContent = 'Saving...';

  const sb = getSb();
  const { error } = await sb.from('profiles').upsert(
    { id: settingsUser.id, username, updated_at: new Date().toISOString() },
    { onConflict: 'id' }
  );

  btn.disabled = false; btn.textContent = 'Save Profile';

  if (error) {
    if (error.message.includes('unique')) setStatus('profile-status', 'Username already taken.', 'var(--red)');
    else setStatus('profile-status', error.message, 'var(--red)');
    return;
  }

  document.getElementById('profile-display-name').textContent = username;
  setStatus('profile-status', '✓ Profile saved');
}

async function changeEmail() {
  const email = document.getElementById('inp-email').value.trim();
  if (!email) { setStatus('email-status', 'Enter a new email.', 'var(--red)'); return; }

  const sb = getSb();
  const { error } = await sb.auth.updateUser({ email });
  if (error) { setStatus('email-status', error.message, 'var(--red)'); return; }
  setStatus('email-status', '✓ Check your new email to confirm the change');
  document.getElementById('inp-email').value = '';
}

async function changePassword() {
  const pass = document.getElementById('inp-password').value;
  const confirm = document.getElementById('inp-password-confirm').value;
  if (!pass) { setStatus('password-status', 'Enter a new password.', 'var(--red)'); return; }
  if (pass.length < 6) { setStatus('password-status', 'At least 6 characters.', 'var(--red)'); return; }
  if (pass !== confirm) { setStatus('password-status', "Passwords don't match.", 'var(--red)'); return; }

  const sb = getSb();
  const { error } = await sb.auth.updateUser({ password: pass });
  if (error) { setStatus('password-status', error.message, 'var(--red)'); return; }
  setStatus('password-status', '✓ Password updated');
  document.getElementById('inp-password').value = '';
  document.getElementById('inp-password-confirm').value = '';
}

async function toggleShareCoaching() {
  const btn = document.getElementById('share-coaching-toggle');
  const isActive = btn.classList.contains('active');
  const newValue = !isActive;
  btn.classList.toggle('active', newValue);

  const sb = getSb();
  const { error } = await sb.from('profiles').upsert(
    { id: settingsUser.id, share_coaching: newValue, updated_at: new Date().toISOString() },
    { onConflict: 'id' }
  );
  if (error) {
    btn.classList.toggle('active', isActive); // revert
    setStatus('coaching-share-status', 'Error saving. Try again.', 'var(--red)');
  } else {
    setStatus('coaching-share-status', newValue ? '✓ Sharing enabled' : '✓ Sharing disabled');
  }
}

async function confirmDelete() {
  if (!confirm('Are you sure? This permanently deletes your account and cannot be undone.')) return;
  if (!confirm('Last chance — delete everything?')) return;
  // Supabase doesn't allow client-side user deletion — direct to support
  alert('To delete your account, email support@fraglog.gg and we\'ll take care of it within 24 hours.');
}

// Avatar upload
document.getElementById('avatar-input').addEventListener('change', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  if (file.size > 10 * 1024 * 1024) { setUploadStatus('Max 10MB', 'var(--red)'); return; }

  setUploadStatus('Uploading...', 'var(--muted)');

  const sb = getSb();
  const ext = file.name.split('.').pop();
  const path = `${settingsUser.id}/avatar.${ext}`;

  const { error } = await sb.storage.from('avatars').upload(path, file, { upsert: true, contentType: file.type });
  if (error) { setUploadStatus('Upload failed.', 'var(--red)'); return; }

  const avatarUrl = `${STORAGE_URL}${path}?t=${Date.now()}`;

  // Save to profile
  await sb.from('profiles').upsert(
    { id: settingsUser.id, avatar_url: avatarUrl, updated_at: new Date().toISOString() },
    { onConflict: 'id' }
  );

  // Update preview
  const img = document.getElementById('avatar-img');
  img.src = avatarUrl;
  img.style.display = 'block';
  document.getElementById('avatar-initials').style.display = 'none';
  setUploadStatus('✓ Photo updated', '#6BCF6B');
});

// Wait for BaseLayout's initAuth() to finish before initialising settings
if (window.__authReady) {
  init();
} else {
  window.__onAuthReady = init;
}
</script>