---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { MAPS, AGENTS, vodCount, getAllVods } from '../data/data.js';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  "https://cvdtykmkajmhlxydhzzl.supabase.co",
  "sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi"
);

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

let user = null;
if (accessToken && refreshToken) {
  const { data } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
  user = data.session?.user ?? null;
}

const totalVods = MAPS.reduce((sum, map) => sum + vodCount(map.id), 0);

// Recently added — last 8 VODs by date
const recentVods = getAllVods()
  .sort((a, b) => new Date(b.date) - new Date(a.date))
  .slice(0, 8);
---
<BaseLayout user={user}>
  <Nav crumbs={[]} user={user} />

  <!-- Hero: search centered -->
  <div class="home-hero" style="background-image: url('/hero-banner.jpg')">
    <div class="home-hero-inner">
      <div class="home-hero-eyebrow">Valorant VOD Library</div>
      <h1 class="home-hero-title">Study the Best. <span>Beat the Rest.</span></h1>
      <p class="home-hero-sub">{totalVods.toLocaleString()}+ Radiant &amp; pro player VODs — filtered by map and agent.</p>
      <div class="home-search-wrap">
        <div class="home-search-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <input
          class="home-search-input"
          id="home-search-input"
          type="text"
          placeholder="Search players, maps, agents..."
          autocomplete="off"
          oninput="homeSearch(this.value)"
          onfocus="this.closest('.home-search-wrap').classList.add('focused')"
          onblur="setTimeout(()=>this.closest('.home-search-wrap').classList.remove('focused'),150)"
        />
        <div class="home-search-results" id="home-search-results"></div>
      </div>
    </div>
  </div>

  <!-- Recently Added -->
  <div class="home-section">
    <div class="home-section-bar">
      <div class="home-section-title">Recently Added</div>
      <a class="home-section-link" href="/search">View all →</a>
    </div>
    <div class="home-recent-grid">
      {recentVods.map(vod => {
        const agent = AGENTS.find(a => a.id === vod.agentId);
        return (
          <div
            class="hrc"
            onclick={`openVideo('${vod.id}','${vod.title.replace(/'/g,"\\'")}','${vod.player}',{agent:'${vod.agentId}',map:'${vod.mapId}',date:'${vod.date}'})`}
          >
            <div class="hrc__thumb">
              <img src={`https://img.youtube.com/vi/${vod.id}/mqdefault.jpg`} alt={vod.title} loading="lazy" />
              <div class="hrc__thumb-overlay"></div>
              <div class="hrc__play">▶</div>
              {agent?.portrait && <img class="hrc__agent" src={agent.portrait} alt={agent.name} />}
            </div>
            <div class="hrc__info">
              <div class="hrc__player">{vod.player}</div>
              <div class="hrc__tags">
                <span class="hrc__tag">{vod.agentId.charAt(0).toUpperCase() + vod.agentId.slice(1)}</span>
                <span class="hrc__tag">{vod.mapId.charAt(0).toUpperCase() + vod.mapId.slice(1)}</span>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Map grid -->
  <div class="home-section">
    <div class="home-section-bar">
      <div class="home-section-title">Browse by Map</div>
      <div class="home-section-count">{MAPS.length} maps</div>
    </div>
    <div class="home-map-grid">
      {MAPS.map(map => {
        const count = vodCount(map.id);
        return (
          <a
            class={`hmc ${count > 0 ? 'hmc--active' : 'hmc--empty'}`}
            href={count > 0 ? `/${map.id}` : undefined}
          >
            <img class="hmc__img" src={map.img} alt={map.name} loading="lazy" />
            <div class="hmc__overlay"></div>
            <div class="hmc__content">
              <div class="hmc__name">{map.name}</div>
              <div class="hmc__count">{count > 0 ? `${count} VODs` : 'Soon'}</div>
            </div>
            <div class="hmc__bar"></div>
          </a>
        );
      })}
    </div>
  </div>

  <Footer />
</BaseLayout>

<script is:inline>
function homeSearch(query) {
  const resultsEl = document.getElementById('home-search-results');
  if (!query || query.length < 2) { resultsEl.innerHTML = ''; resultsEl.style.display = 'none'; return; }

  const q = query.toLowerCase();
  const results = [];

  // Search maps
  if (typeof MAPS !== 'undefined') {
    MAPS.forEach(map => {
      if (map.name.toLowerCase().includes(q)) {
        results.push({ type: 'map', label: map.name, sub: 'Map', href: `/${map.id}` });
      }
    });
  }

  // Search agents
  if (typeof AGENTS !== 'undefined') {
    AGENTS.forEach(agent => {
      if (agent.name.toLowerCase().includes(q)) {
        results.push({ type: 'agent', label: agent.name, sub: agent.role, href: `/search?q=${encodeURIComponent(agent.name)}` });
      }
    });
  }

  if (results.length === 0) {
    // Generic search
    results.push({ type: 'search', label: `Search "${query}"`, sub: 'Players, VODs', href: `/search?q=${encodeURIComponent(query)}` });
  }

  resultsEl.innerHTML = results.slice(0, 6).map(r => `
    <a class="hsr-item" href="${r.href}">
      <span class="hsr-label">${r.label}</span>
      <span class="hsr-sub">${r.sub}</span>
    </a>
  `).join('');
  resultsEl.style.display = 'block';
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    const r = document.getElementById('home-search-results');
    if (r) { r.innerHTML = ''; r.style.display = 'none'; }
  }
});
</script>