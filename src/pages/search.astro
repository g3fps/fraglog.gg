---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getAllVods, AGENTS, MAPS } from '../data/data.js';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  "https://cvdtykmkajmhlxydhzzl.supabase.co",
  "sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi"
);

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

let user = null;
if (accessToken && refreshToken) {
  const { data } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
  user = data.session?.user ?? null;
}

const allVods = getAllVods();
const agentRoles = Object.fromEntries(AGENTS.map((a: any) => [a.id, a.role]));
---
<BaseLayout title="Search — fraglog.gg" description="Search Valorant VODs by player, map, or agent on FragLog.gg" user={user}>
  <Nav crumbs={[{ label: 'ALL MAPS', href: '/' }, { label: 'SEARCH' }]} user={user} />
  <div class="search-hero">
    <div class="search-hero-wrap">
      <div class="search-hero-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </div>
      <input
        type="text"
        id="search-input"
        class="search-hero-input"
        placeholder="Search players, maps, agents..."
        autocomplete="off"
        />
    </div>
    <div class="search-meta" id="search-meta"></div>
  </div>
  <div class="page-content" style="padding-top:1.5rem;">
    <div class="vod-controls">
      <div class="vod-field">
        <span class="vod-field-label">Role</span>
        <select class="vod-select" id="f-role" aria-label="Filter by role">
          <option value="">All roles</option>
          <option value="Duelist">Duelist</option>
          <option value="Controller">Controller</option>
          <option value="Sentinel">Sentinel</option>
          <option value="Initiator">Initiator</option>
        </select>
      </div>
      <div class="vod-field">
        <span class="vod-field-label">Map</span>
        <select class="vod-select" id="f-map" aria-label="Filter by map">
          <option value="">All maps</option>
          {MAPS.map((m: any) => <option value={m.id}>{m.name}</option>)}
        </select>
      </div>
      <div class="vod-field">
        <span class="vod-field-label">Sort</span>
        <select class="vod-select" id="f-sort" aria-label="Sort results">
          <option value="newest">Newest</option>
          <option value="oldest">Oldest</option>
          <option value="player">Player A–Z</option>
        </select>
      </div>
    </div>
    <div class="video-grid" id="search-grid"></div>
  </div>
  <Footer />
</BaseLayout>

<script define:vars={{ allVods, agentRoles }}>
const ALL_VODS = allVods;
const AGENT_ROLES = agentRoles;

function renderVods(vods) {
  const grid = document.getElementById("search-grid");
  if (!vods.length) {
    grid.innerHTML = '<div class="empty"><strong>No results</strong>Try a different player, map, or agent</div>';
    return;
  }
  grid.innerHTML = vods.map(v => `
    <div class="video-card">
      <div class="video-thumb" data-vid="${v.id}" style="cursor:pointer">
        <img src="https://img.youtube.com/vi/${v.id}/mqdefault.jpg" alt="${v.title}" loading="lazy" decoding="async">
        <div class="play-overlay"><div class="play-icon"><div class="play-tri"></div></div></div>
      </div>
      <div class="video-info">
        <div class="video-tag-row">
          <span class="video-map-tag">${v.mapName||''}</span>
          <span class="video-agent-tag">${v.agentName||''}</span>
        </div>
        <div class="video-title" data-vid="${v.id}" style="cursor:pointer">${v.title}</div>
        <div class="video-meta-row">
          <a class="video-player" href="/player/${v.player.toLowerCase().replace(/\//g,'').replace(/ /g,'-')}" onclick="event.stopPropagation()">${v.player}</a>
          ${v.date ? `<span class="video-date">${new Date(v.date).toLocaleDateString('en-US',{month:'short',year:'numeric'})}</span>` : ''}
        </div>
        <div class="notes-section" data-vid="${v.id}" data-title="${v.title.replace(/"/g,'&quot;')}" data-player="${v.player}">
          <span class="note-login-prompt"><span class="note-auth-link" onclick="openAuth()">Sign in</span> to save &amp; add notes</span>
        </div>
      </div>
    </div>
  `).join("");

  grid.onclick = e => {
    const el = e.target.closest("[data-vid]");
    if (el && !e.target.closest("button") && !e.target.closest("a")) {
      const vod = ALL_VODS.find(v => v.id === el.dataset.vid);
      if (vod) openVideo(vod.id, vod.title, vod.player, { agent: vod.agentId, map: vod.mapId, date: vod.date });
    }
  };

  updateSearchActions();
  if (window.applyWatchProgress) window.applyWatchProgress();
}

function applyFilters() {
  const q = (document.getElementById("search-input").value || "").toLowerCase().trim();
  const role = document.getElementById("f-role").value;
  const map = document.getElementById("f-map").value;
  const sort = document.getElementById("f-sort").value;

  let results = ALL_VODS.filter(v => {
    if (role && AGENT_ROLES[v.agentId] !== role) return false;
    if (map && v.mapId !== map) return false;
    if (q) {
      const s = [v.title, v.player, v.mapName, v.agentName].join(" ").toLowerCase();
      if (!s.includes(q)) return false;
    }
    return true;
  });

  results.sort((a, b) => {
    if (sort === "player") return (a.player || "").localeCompare(b.player || "");
    const da = a.date || "", db = b.date || "";
    if (!da) return 1;
    if (!db) return -1;
    return sort === "oldest" ? da.localeCompare(db) : db.localeCompare(da);
  });

  const meta = document.getElementById("search-meta");
  const filtered = q || role || map;
  meta.textContent = filtered
    ? `${results.length} result${results.length !== 1 ? "s" : ""}`
    : `${ALL_VODS.length} VODs`;
  renderVods(results);

  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (role) params.set("role", role);
  if (map) params.set("map", map);
  if (sort && sort !== "newest") params.set("sort", sort);
  const qs = params.toString();
  history.replaceState({}, "", qs ? "/search?" + qs : "/search");
}

function updateSearchActions() {
  if (!currentUser) return;
  document.querySelectorAll("#search-grid .notes-section").forEach(el => {
    const vid = el.dataset.vid;
    const title = el.dataset.title;
    const player = el.dataset.player;
    const noteText = getUserNote(vid) ? "View notes" : "Add notes";
    const noteClass = getUserNote(vid) ? "has-note" : "";
    const favText = isFav(vid) ? "♥ Saved" : "♡ Save";
    const favClass = isFav(vid) ? "has-note" : "";
    el.innerHTML = `
      <button class="notes-btn ${noteClass}" onclick="openNotes('${vid}','${title.replace(/'/g,"\\'")}','${player}')">📝 ${noteText}</button>
      <button class="notes-btn ${favClass}" onclick="toggleFav('${vid}',this)">${favText}</button>`;
  });
}

function onAuthChange() { updateSearchActions(); }

// Init — hydrate all controls from the URL, then wire them
const params = new URLSearchParams(window.location.search);
const input = document.getElementById("search-input");
if (input) input.value = params.get("q") || "";
const roleSel = document.getElementById("f-role");
const mapSel = document.getElementById("f-map");
const sortSel = document.getElementById("f-sort");
const setIfValid = (sel, val) => { if (val && [...sel.options].some(o => o.value === val)) sel.value = val; };
setIfValid(roleSel, params.get("role"));
setIfValid(mapSel, params.get("map"));
setIfValid(sortSel, params.get("sort"));

if (input) input.addEventListener("input", applyFilters);
[roleSel, mapSel, sortSel].forEach(sel => sel.addEventListener("change", applyFilters));
applyFilters();

window.__onAuthReady = updateSearchActions;
if (window.__authReady) updateSearchActions();
</script>