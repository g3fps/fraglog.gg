---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { formatDate } from '../../data/data.js';
import { getAllVods } from '../../lib/vods.js';
import { getSessionUser } from '../../lib/auth.js';

const { user } = await getSessionUser(Astro.cookies);

const { player } = Astro.params;
const allVods = await getAllVods();
const playerVods = allVods.filter((v: any) => v.player.toLowerCase() === (player ?? '').toLowerCase());
if (!playerVods.length) return Astro.redirect('/');

const displayName = playerVods[0].player;
const title = `${displayName} VODs — fraglog.gg`;
const description = `Watch all ${playerVods.length} ${displayName} VODs on FragLog.gg`;
---
<BaseLayout title={title} description={description} user={user}>
  <Nav crumbs={[{ label: 'ALL MAPS', href: '/' }, { label: displayName.toUpperCase() }]} user={user} />
  <div class="page-content">
    <div class="videos-header">
      <div>
        <div class="hero-eyebrow">Player Profile</div>
        <div class="videos-title">{displayName}</div>
        <div class="hero-sub">{playerVods.length} VOD{playerVods.length !== 1 ? 's' : ''} in the library</div>
      </div>
    </div>

    <div class="video-grid" id="video-grid">
      {playerVods.map(v => (
        <div class="video-card"
          data-vid={v.id}
          data-title={v.title}
          data-player={v.player}
          data-date={v.date ? formatDate(v.date) : ''}
          data-note=""
          data-map-id={v.mapId}
          data-map-name={v.mapName}
          data-agent-id={v.agentId}
          data-agent-name={v.agentName}
          style="cursor:pointer"
        >
          <div class="video-thumb">
            <img src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`} alt={v.title} loading="lazy" />
            <div class="play-overlay">
              <div class="play-icon"><div class="play-tri"></div></div>
            </div>
            <div class="vc-actions">
              <button class="vc-action-btn" data-fav-btn={v.id} title="Save to favorites">♡</button>
            </div>
          </div>
          <div class="video-info">
            <div class="video-tag-row">
              <span class="video-map-tag">{v.mapName}</span>
              <span class="video-agent-tag">{v.agentName}</span>
            </div>
            <div class="video-title">{v.title}</div>
            <div class="video-meta-row">
              {v.date && <span class="video-date">{formatDate(v.date)}</span>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <Footer />
</BaseLayout>

<script is:inline>
document.addEventListener('click', function(e) {
  const card = e.target.closest('.video-card[data-vid]');
  if (!card) return;
  if (e.target.closest('button') || e.target.closest('a')) return;
  openVideo(card.dataset.vid, card.dataset.title, card.dataset.player, {
    date: card.dataset.date || '',
    adminNote: card.dataset.note || '',
    mapId: card.dataset.mapId || '',
    mapName: card.dataset.mapName || '',
    agentId: card.dataset.agentId || '',
    agentName: card.dataset.agentName || ''
  });
});

function onFavChange() {}
window.__onAuthReady = function() {};
if (window.__authReady) {}
</script>