---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { MAPS, AGENTS } from '../data/data.js';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  "https://cvdtykmkajmhlxydhzzl.supabase.co",
  "sb_publishable_I16eAnYgsA9fd8ZMlmFQtA_RxepSaXi"
);

const TURNSTILE_SITE_KEY = import.meta.env.TURNSTILE_SITE_KEY || '';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

let user = null;
if (accessToken && refreshToken) {
  const { data } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
  user = data.session?.user ?? null;
}
---
<BaseLayout title="Submit a VOD — FragLog.gg" description="Submit a Radiant or pro player Valorant VOD for review on FragLog.gg">
  <Nav crumbs={[{ label: 'ALL MAPS', href: '/' }, { label: 'SUBMIT A VOD' }]} />
  <div class="page-content">
    <div class="hero">
      <div class="hero-title">Submit a VOD</div>
      <div class="hero-sub">Found a great Radiant or pro player VOD? Submit it for review.</div>
    </div>
    <div class="submit-wrap">
      <div class="myvods-form">
        <div class="myvods-fields">
          <div class="myvods-field">
            <label>YouTube URL</label>
            <input type="text" id="sub-url" placeholder="https://youtube.com/watch?v=..." oninput="subExtractId()">
            <div class="mv-id-display" id="sub-id-display"></div>
          </div>
          <div class="myvods-row">
            <div class="myvods-field">
              <label>Map</label>
              <select id="sub-map">
                <option value="">Select map...</option>
                {MAPS.map(m => <option value={m.id}>{m.name}</option>)}
              </select>
            </div>
            <div class="myvods-field">
              <label>Agent</label>
              <select id="sub-agent">
                <option value="">Select agent...</option>
                <optgroup label="Duelists">
                  {AGENTS.filter(a=>a.role==="Duelist").map(a => <option value={a.id}>{a.name}</option>)}
                </optgroup>
                <optgroup label="Controllers">
                  {AGENTS.filter(a=>a.role==="Controller").map(a => <option value={a.id}>{a.name}</option>)}
                </optgroup>
                <optgroup label="Sentinels">
                  {AGENTS.filter(a=>a.role==="Sentinel").map(a => <option value={a.id}>{a.name}</option>)}
                </optgroup>
                <optgroup label="Initiators">
                  {AGENTS.filter(a=>a.role==="Initiator").map(a => <option value={a.id}>{a.name}</option>)}
                </optgroup>
              </select>
            </div>
          </div>
          <div class="myvods-field">
            <label>Player / Channel name</label>
            <input type="text" id="sub-player" placeholder="e.g. tarik, demon1, s0m">
          </div>
          <div class="myvods-field">
            <label>Why should this be added? (optional)</label>
            <input type="text" id="sub-note" placeholder="e.g. insane performance, great util usage">
          </div>
          <input type="text" id="sub-hp" autocomplete="off" tabindex="-1" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" aria-hidden="true">
          {TURNSTILE_SITE_KEY && <div id="sub-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark" style="margin-bottom:14px"></div>}
          <button class="auth-btn primary sub-btn" onclick="submitVodRequest()" id="sub-btn">Submit for Review</button>
          <div class="mv-error" id="sub-error"></div>
          <div id="sub-success" class="sub-success">✓ Submitted! We'll review it shortly.</div>
        </div>
      </div>
    </div>
  </div>
  <Footer />
</BaseLayout>

<script is:inline>
let subVideoId = "";

// Cloudflare Turnstile is loaded globally by BaseLayout (explicit mode). Render this page's widget once ready.
let subTurnstileId = null;
function renderSubTurnstile(attempt = 0) {
  const el = document.getElementById("sub-turnstile");
  if (!el) return; // not configured (no site key)
  if (!window.turnstile) { if (attempt < 25) setTimeout(() => renderSubTurnstile(attempt + 1), 150); return; }
  if (subTurnstileId !== null) return;
  try { subTurnstileId = window.turnstile.render(el, { sitekey: el.dataset.sitekey, theme: "dark" }); } catch (e) {}
}
renderSubTurnstile();

function subExtractId() {
  const url = document.getElementById("sub-url").value.trim();
  const match = url.match(/(?:v=|youtu\.be\/|embed\/)([a-zA-Z0-9_-]{11})/);
  const display = document.getElementById("sub-id-display");
  if (match) { subVideoId = match[1]; display.textContent = "ID: " + subVideoId; }
  else { subVideoId = ""; display.textContent = url.length > 5 ? "No video ID found" : ""; }
}

async function submitVodRequest() {
  const mapId = document.getElementById("sub-map").value;
  const agentId = document.getElementById("sub-agent").value;
  const player = document.getElementById("sub-player").value.trim();
  const note = document.getElementById("sub-note").value.trim();
  const errEl = document.getElementById("sub-error");
  const btn = document.getElementById("sub-btn");

  errEl.textContent = "";
  document.getElementById("sub-success").style.display = "none";

  if (document.getElementById("sub-hp").value) return;
  if (!subVideoId) { errEl.textContent = "Paste a valid YouTube URL."; return; }
  if (!mapId) { errEl.textContent = "Select a map."; return; }
  if (!agentId) { errEl.textContent = "Select an agent."; return; }
  if (!player) { errEl.textContent = "Enter the player name."; return; }

  // Require the human-check token when the widget is present
  let tsToken = "";
  if (window.turnstile && subTurnstileId !== null) {
    tsToken = window.turnstile.getResponse(subTurnstileId) || "";
    if (!tsToken) { errEl.textContent = "Please complete the verification."; return; }
  }

  btn.textContent = "Submitting..."; btn.disabled = true;

  let error = null;
  try {
    const res = await fetch("/api/submit-vod", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        video_id: subVideoId, map_id: mapId, agent_id: agentId,
        player, note,
        hp: document.getElementById("sub-hp").value,
        turnstileToken: tsToken
      })
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) error = { message: data.error || ("Error " + res.status) };
  } catch {
    error = { message: "Network error." };
  }
  if (window.turnstile && subTurnstileId !== null) { try { window.turnstile.reset(subTurnstileId); } catch (e) {} }

  btn.textContent = "Submit for Review"; btn.disabled = false;
  if (error) { errEl.textContent = "Error submitting: " + error.message; return; }

  document.getElementById("sub-success").style.display = "block";
  document.getElementById("sub-url").value = "";
  document.getElementById("sub-map").value = "";
  document.getElementById("sub-agent").value = "";
  document.getElementById("sub-player").value = "";
  document.getElementById("sub-note").value = "";
  document.getElementById("sub-id-display").textContent = "";
  subVideoId = "";
}
</script>
