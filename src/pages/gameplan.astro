async function saveGoal() {
  const title = document.getElementById('goal-title').value.trim();
  const errEl = document.getElementById('goal-modal-error');
  if (!title) { errEl.textContent = 'Goal title is required.'; return; }

  const btn = document.getElementById('goal-save-btn');
  btn.textContent = 'Saving...'; btn.disabled = true;

  const sb = initSupabase();
  const payload = {
    user_id: currentUser.id,
    type: goalType,
    title,
    current_value: (goalType === 'rank' ? document.getElementById('goal-current-rank').value : document.getElementById('goal-current-text').value.trim()) || null,
    target: (goalType === 'rank' ? document.getElementById('goal-target-rank').value : document.getElementById('goal-target-text').value.trim()) || null,
    deadline: document.getElementById('goal-deadline').value || null,
    notes: document.getElementById('goal-notes').value.trim() || null,
    current_rr: parseInt(document.getElementById('goal-current-rr').value) || 0,
  };

  let error;
  if (editingGoalId) {
    const { error: e } = await sb.from('goals').update(payload).eq('id', editingGoalId).eq('user_id', currentUser.id);
    error = e;
    if (!e) goals = goals.map(g => g.id === editingGoalId ? { ...g, ...payload } : g);
  } else {
    const { data, error: e } = await sb.from('goals').insert({ ...payload, wins: 0, losses: 0, win_rr: [], loss_rr: [], dodge_rr: [] }).select().single();
    error = e;
    if (!e && data) goals.push(data);
  }

  btn.textContent = 'Save Goal'; btn.disabled = false;
  if (error) { errEl.textContent = error.message; return; }

  closeGoalModal();
  renderGoals();
  renderRoutine();
}

async function deleteGoal(id) {
  if (!confirm('Delete this goal?')) return;
  const sb = initSupabase();
  await sb.from('goals').delete().eq('id', id).eq('user_id', currentUser.id);
  goals = goals.filter(g => g.id !== id);
  renderGoals();
  renderRoutine();
}

// ── W/L tracking ─────────────────────────────────────────────
let _pendingRR = null;

function startLogRR(id, type) {
  _pendingRR = { id, type };
  const btns = document.getElementById(`wl-btns-${id}`);
  if (!btns) return;
  const label = type === 'win' ? 'RR gained' : type === 'dodge' ? 'RR lost (dodge)' : 'RR lost';
  const ph = type === 'win' ? '22' : type === 'dodge' ? '3' : '18';
  btns.innerHTML = `<div class="goal-wl-rr-row">
    <span class="goal-wl-rr-label">${label}:</span>
    <input type="number" class="goal-wl-rr-input" id="rr-inp-${id}" min="1" max="100" placeholder="${ph}" autofocus>
    <button class="goal-wl-rr-ok" onclick="confirmRR('${id}')">✓</button>
    <button class="goal-wl-rr-cancel" onclick="renderGoals()">✕</button>
  </div>`;
  const inp = document.getElementById(`rr-inp-${id}`);
  inp?.focus();
  inp?.addEventListener('keydown', e => {
    if (e.key === 'Enter') confirmRR(id);
    if (e.key === 'Escape') { _pendingRR = null; renderGoals(); }
  });
}

async function confirmRR(id) {
  if (!_pendingRR || _pendingRR.id !== id) return;
  const rr = parseInt(document.getElementById(`rr-inp-${id}`)?.value);
  if (!rr || rr < 1 || rr > 100) { document.getElementById(`rr-inp-${id}`)?.focus(); return; }
  const { type } = _pendingRR;
  _pendingRR = null;

  const sb = initSupabase();
  const goal = goals.find(g => g.id === id);
  if (!goal) return;

  if (type === 'win') {
    goal.win_rr = [...(Array.isArray(goal.win_rr) ? goal.win_rr : []), rr];
    goal.wins = goal.win_rr.length;
  } else if (type === 'dodge') {
    // Dodges cost RR but don't count as a game — leave wins/losses untouched
    goal.dodge_rr = [...(Array.isArray(goal.dodge_rr) ? goal.dodge_rr : []), rr];
  } else {
    goal.loss_rr = [...(Array.isArray(goal.loss_rr) ? goal.loss_rr : []), rr];
    goal.losses = goal.loss_rr.length;
  }

  const update = { win_rr: goal.win_rr, wins: goal.wins, loss_rr: goal.loss_rr, losses: goal.losses, dodge_rr: goal.dodge_rr };
  await ensureSession(sb);
  const { error: rrErr } = await sb.from('goals').update(update).eq('id', id).eq('user_id', currentUser.id);
  if (rrErr) console.error('RR save failed:', rrErr.message);
  renderGoals();
}

// ── Save helper ───────────────────────────────────────────────
async function saveRoutine() {
  const sb = initSupabase();
  await ensureSession(sb);
  const { error } = await sb.from('routine').upsert({
    user_id: currentUser.id,
    tasks: routineData.tasks,
    generated_at: routineData.generated_at,
    time_per_day: routineData.time_per_day,
    daily_generate_date: routineData.daily_generate_date,
    daily_finetune_count: routineData.daily_finetune_count,
    daily_finetune_date: routineData.daily_finetune_date,
  }, { onConflict: 'user_id' });
  if (error) console.error('routine save failed:', error.message);
  return error;
}

// Routine mutations the client can't do directly (routine table is service-key
// only under RLS) — clearing and time-per-day go through /api/save-routine.
async function postRoutineUpdate(payload) {
  try {
    const session = (await initSupabase().auth.getSession()).data.session;
    const res = await fetch('/api/save-routine', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        ...(session?.access_token ? { Authorization: `Bearer ${session.access_token}` } : {}),
      },
      body: JSON.stringify(payload),
    });
    if (res.status === 401) { openAuth(); return 'unauthorized'; }
    if (!res.ok) {
      const data = await res.json().catch(() => ({}));
      return data.error || 'save failed';
    }
    return null;
  } catch (e) {
    return e.message || 'network error';
  }
}

// ── Clear routine ─────────────────────────────────────────────
async function clearRoutine() {
  if (!confirm('Clear your gameplan?')) return;
  routineData.tasks = null;
  routineData.generated_at = null;
  renderRoutine();
  const err = await postRoutineUpdate({ clear: true });
  if (err) console.error('clear routine failed:', err);
}

// ── Routine generation ────────────────────────────────────────
async function generateRoutine() {
  const btn = document.getElementById('routine-regen-btn');
  const el = document.getElementById('routine-tasks-container');
  if (btn) { btn.textContent = 'Generating...'; btn.disabled = true; }
  el.innerHTML = `<div class="routine-generating">
    <div class="routine-gen-dots"><span></span><span></span><span></span></div>
    <div>Building your gameplan...</div>
  </div>`;

  try {
    const session = (await initSupabase().auth.getSession()).data.session;
    const res = await fetch('/api/generate-routine', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        ...(session?.access_token ? { Authorization: `Bearer ${session.access_token}` } : {}),
      },
      body: JSON.stringify({
        goals,
        timePerDay: routineData.time_per_day || 60,
        routineDetails: prefsToText(routinePrefs),
        wakeTime: routinePrefs.wake_time || '',
      }),
    });

    if (res.status === 401) { openAuth(); return; }
    if (res.status === 429) {
      renderRoutine();
      const el = document.getElementById('routine-tasks-container');
      const notice = document.createElement('div');
      notice.className = 'routine-limit-notice';
      notice.textContent = 'Out of generations for today — resets at midnight.';
      el?.prepend(notice);
      return;
    }

    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed to generate');

    routineData.tasks = data.routine;
    routineData.generated_at = data.generated_at || new Date().toISOString();
    if (data.daily_generate_date) routineData.daily_generate_date = data.daily_generate_date;
    if (data.daily_finetune_count !== undefined) routineData.daily_finetune_count = data.daily_finetune_count;
    if (data.daily_finetune_date) routineData.daily_finetune_date = data.daily_finetune_date;
    completedToday.clear();
    saveCompletion();

    if (data.save_error) {
      console.warn('Server save failed, attempting client backup:', data.save_error);
      await saveRoutine();
    }

    renderRoutine();
  } catch (e) {
    el.innerHTML = `<div class="routine-error">${esc(e.message || 'Something went wrong. Try again.')}</div>`;
    if (btn) { btn.textContent = '↺ Regenerate'; btn.disabled = false; }
  }
}

// ── Fine tune ─────────────────────────────────────────────────
function fineTuneUsageLabel() {
  if (isAdmin()) return '∞ fine tunes';
  const today = new Date().toISOString().slice(0, 10);
  const sameDay = routineData.daily_finetune_date === today;
  const used = sameDay ? (routineData.daily_finetune_count || 0) : 0;
  const left = 3 - used;
  if (left <= 0) return 'Fine tune limit reached for today';
  return `${left}/3 fine tunes remaining today`;
}

async function fineTuneRoutine() {
  const input = document.getElementById('finetune-input');
  const instruction = input?.value?.trim();
  if (!instruction) { input?.focus(); return; }

  const routine = routineData.tasks && !Array.isArray(routineData.tasks) ? routineData.tasks : null;
  if (!routine?.schedule?.length) { alert('Generate a gameplan first.'); return; }

  const today = new Date().toISOString().slice(0, 10);
  const sameDay = routineData.daily_finetune_date === today;
  const used = sameDay ? (routineData.daily_finetune_count || 0) : 0;
  if (!isAdmin() && used >= 3) { alert('Fine tune limit reached for today (3/3).'); return; }

  const btn = document.getElementById('finetune-btn');
  btn.textContent = 'Tuning...'; btn.disabled = true;

  try {
    const session = (await initSupabase().auth.getSession()).data.session;
    const res = await fetch('/api/generate-routine', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        ...(session?.access_token ? { Authorization: `Bearer ${session.access_token}` } : {}),
      },
      body: JSON.stringify({
        goals,
        timePerDay: routineData.time_per_day || 60,
        routineDetails: prefsToText(routinePrefs),
        wakeTime: routinePrefs.wake_time || '',
        fineTune: instruction,
        currentRoutine: routine,
      }),
    });

    if (res.status === 401) { openAuth(); return; }

    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed to fine tune');

    routineData.tasks = data.routine;
    routineData.generated_at = data.generated_at || new Date().toISOString();
    if (data.daily_finetune_count !== undefined) routineData.daily_finetune_count = data.daily_finetune_count;
    if (data.daily_finetune_date) routineData.daily_finetune_date = data.daily_finetune_date;

    if (data.save_error) {
      console.warn('Server save failed, attempting client backup:', data.save_error);
      await saveRoutine();
    }

    if (input) input.value = '';

    renderRoutine();
  } catch (e) {
    const el = document.getElementById('routine-tasks-container');
    if (el) el.innerHTML += `<div class="routine-error" style="margin-top:8px">${esc(e.message || 'Something went wrong.')}</div>`;
  }

  btn.textContent = 'Fine tune'; btn.disabled = false;
}

