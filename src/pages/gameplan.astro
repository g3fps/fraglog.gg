function prefsToText(prefs) {
  if (!prefs) return '';
  const parts = [];
  const iMap = { light:'light and easy — keep it relaxed', moderate:'moderate', intense:'intense and challenging — push hard', grind:'maximum grind mode, brutal and demanding' };
  if (prefs.intensity && iMap[prefs.intensity]) parts.push(`Intensity: ${iMap[prefs.intensity]}`);
  if (prefs.notes) parts.push(prefs.notes);
  return parts.join('. ');
}

// ── Time per day modal ────────────────────────────────────────
function editTimeModal() {
  document.getElementById('time-input').value = routineData.time_per_day || 60;
  document.getElementById('time-modal').classList.add('open');
}

function closeTimeModal() {
  document.getElementById('time-modal').classList.remove('open');
}

function closeTimeModalClick(e) {
  if (e.target === document.getElementById('time-modal')) closeTimeModal();
}

async function saveTimePerDay() {
  const val = parseInt(document.getElementById('time-input').value, 10);
  if (!val || val < 1) { alert('Enter at least 1 minute.'); return; }
  routineData.time_per_day = val;
  closeTimeModal();
  renderRoutine();
  const err = await postRoutineUpdate({ timePerDay: val });
  if (err) console.error('time per day save failed:', err);
}

// ── Helpers ───────────────────────────────────────────────────
function esc(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function timeAgo(iso) {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  return `${Math.floor(hrs / 24)}d ago`;
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { closeGoalModal(); closeTimeModal(); }
});
</script>
