  document.getElementById('goal-target-text').style.display = isRankType ? 'none' : '';
  document.getElementById('goal-current-rank').style.display = isRankType ? '' : 'none';
  document.getElementById('goal-target-rank').style.display = isRankType ? '' : 'none';
