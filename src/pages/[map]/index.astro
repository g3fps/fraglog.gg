---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { MAPS, AGENTS, ROLES_ORDER, ROLE_DOTS } from '../../data/data.js';
import { getMapVodCounts } from '../../lib/vods.js';
import { getSessionUser } from '../../lib/auth.js';

const { user } = await getSessionUser(Astro.cookies);

const { map: mapId } = Astro.params;
const mapData = MAPS.find(m => m.id === mapId);

if (!mapData) return Astro.redirect('/');

const vodCounts = await getMapVodCounts(mapId as string);

const title = `${mapData.name} Valorant VODs — fraglog.gg`;
const description = `Watch Radiant and pro player Valorant VODs on ${mapData.name}, filtered by agent. Study ${mapData.name} gameplay from the best players in the world on fraglog.gg.`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "fraglog.gg", "item": "https://fraglog.gg" },
    { "@type": "ListItem", "position": 2, "name": `${mapData.name} VODs`, "item": `https://fraglog.gg/${mapId}/` }
  ]
});
---
<BaseLayout title={title} description={description} ogImage={mapData.img} canonical={`https://fraglog.gg/${mapId}/`} jsonLd={jsonLd} user={user}>
  <div id="map-bg-layer" style={`background-image:url(${mapData.img});opacity:1`}></div>
  <div class="agents-bg-overlay"></div>
  <Nav crumbs={[{ label: 'ALL MAPS', href: '/' }, { label: mapData.name.toUpperCase() }]} user={user} />
  <div class="page-content">
    <h1 class="agents-page-title">{mapData.name}</h1>
    <div class="agent-filter-bar">
      <div class="agent-role-pills">
        <button class="role-pill active" type="button" data-role="">All</button>
        {ROLES_ORDER.map((r: string) => <button class="role-pill" type="button" data-role={r}>{r}s</button>)}
      </div>
    </div>
    {ROLES_ORDER.map(role => {
      const roleAgents = AGENTS.filter(a => a.role === role);
      return (
        <div class="agent-section" data-role={role}>
          <div class="role-header">
            <div class="role-dot" style={`background:${(ROLE_DOTS as Record<string, string>)[role]}`}></div>
            {role}s
          </div>
          <div class="agent-grid">
            {roleAgents.map(agent => {
              const hasVods = (vodCounts[agent.id] || 0) > 0;
              return (
               <a   class={`agent-card ${hasVods ? 'has-vods' : 'no-vods'}`}
                  href={hasVods ? `/${mapId}/${agent.id}/` : undefined}
                  style={`--agent-color:${agent.color}`}
                >
                  <div class="agent-portrait-wrap">
                    {agent.portrait
                      ? <img class="agent-portrait-img" src={agent.portrait} alt={agent.name} loading="lazy" />
                      : <div class="agent-icon-placeholder">{agent.name[0]}</div>
                    }
                    <div class="agent-portrait-overlay"></div>
                  </div>
                  <div class="agent-card-info">
                    <div class="agent-name">{agent.name}</div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>
  <Footer />
</BaseLayout>

<script is:inline>
(function initAgentFilters() {
  const pills = document.querySelectorAll('.role-pill');
  const sections = document.querySelectorAll('.agent-section');
  if (!sections.length) return;

  pills.forEach(p => p.addEventListener('click', () => {
    pills.forEach(x => x.classList.remove('active'));
    p.classList.add('active');
    const role = p.dataset.role;
    sections.forEach(sec => {
      sec.style.display = (!role || role === sec.dataset.role) ? '' : 'none';
    });
  }));
})();
</script>

